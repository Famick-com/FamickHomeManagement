# Famick Home Management - Environment Configuration
# Copy this file to .env and update the values, or run setup.sh to auto-generate secrets.

# Database
DB_PASSWORD=changeme123

# JWT Authentication (legacy symmetric key, kept for backwards compatibility)
JWT_SECRET_KEY=your-secret-key-change-this-min-32-characters-long

# HTTPS Certificate
CERT_PASSWORD=password

# Email (optional - required for password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENABLE_SSL=true
SMTP_FROM_EMAIL=noreply@localhost
SMTP_FROM_NAME=Famick Home Management

# pgAdmin (optional - only used with --profile tools)
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
