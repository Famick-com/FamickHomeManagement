@inject NavigationManager Navigation
@inject ILocalizer L
@inject INavMenuPreferenceStorage NavMenuStorage
@inject ISubscriptionStateProvider SubscriptionState

<MudNavMenu>
    @* Standalone items at top — Dashboard and My Home are always allowed *@
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">@L["nav.dashboard"]</MudNavLink>
    <MudNavLink Href="/my-home" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Home">@L["nav.myHome"]</MudNavLink>

    @* Shopping — gated *@
    @if (SubscriptionState.IsFeatureAvailable("shopping"))
    {
        <MudNavLink Href="/shopping-lists" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ShoppingCart">@L["nav.shoppingLists"]</MudNavLink>
    }
    else
    {
        <MudNavLink Icon="@Icons.Material.Filled.ShoppingCart" OnClick="@(() => ShowUpgrade("shopping"))" Class="locked-nav-item">
            @L["nav.shoppingLists"] <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Class="ml-1" />
        </MudNavLink>
    }

    @* Calendar — always allowed *@
    <MudNavLink Href="/calendar" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CalendarMonth">@L["nav.calendar"]</MudNavLink>

    @* Meal Planner — gated *@
    @if (SubscriptionState.IsFeatureAvailable("mealplanner"))
    {
        <MudNavLink Href="/meal-planner" Match="NavLinkMatch.Prefix" Icon="@CustomIcons.MealPlanner">@L["nav.mealPlanner"]</MudNavLink>
    }
    else
    {
        <MudNavLink Icon="@CustomIcons.MealPlanner" OnClick="@(() => ShowUpgrade("mealplanner"))" Class="locked-nav-item">
            @L["nav.mealPlanner"] <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Class="ml-1" />
        </MudNavLink>
    }

    @* Groceries section (collapsible) *@
    <MudNavGroup Title="@L["nav.inventory"]" Icon="@Icons.Material.Filled.Kitchen" Expanded="@_groceriesExpanded" ExpandedChanged="@(e => OnExpandedChanged("groceries", e))">
        @GatedNavLink("/inventory-session", Icons.Material.Filled.QrCodeScanner, L["nav.inventorySession"], "inventory")
        @GatedNavLink("/stock", Icons.Material.Filled.Inventory, L["nav.stockOverview"], "inventory")
        @GatedNavLink("/products", Icons.Material.Filled.Category, L["nav.products"], "products")
        @GatedNavLink("/recipes", Icons.Material.Filled.MenuBook, L["nav.recipes"], "recipes")
        @GatedNavLink("/meals", Icons.Material.Filled.LunchDining, L["nav.meals"], "mealplanner")
        @GatedNavLink("/settings/stores", Icons.Material.Filled.Store, L["nav.stores"], "products")
    </MudNavGroup>

    @* Household section (collapsible) *@
    <MudNavGroup Title="@L["nav.household"]" Icon="@Icons.Material.Filled.FamilyRestroom" Expanded="@_householdExpanded" ExpandedChanged="@(e => OnExpandedChanged("household", e))">
        @GatedNavLink("/contacts", Icons.Material.Filled.Contacts, L["nav.contacts"], "contacts")
        @GatedNavLink("/chores", Icons.Material.Filled.CleaningServices, L["nav.chores"], "chores")
        @GatedNavLink("/equipment", Icons.Material.Filled.Build, L["nav.equipment"], "equipment")
        @GatedNavLink("/storage", Icons.Material.Filled.Inventory2, L["nav.storageBins"], "storagebins")
    </MudNavGroup>

    @* System section (collapsible) *@
    <MudNavGroup Title="@L["nav.system"]" Icon="@Icons.Material.Filled.Settings" Expanded="@_systemExpanded" ExpandedChanged="@(e => OnExpandedChanged("system", e))">
        <MudNavLink Href="/settings/locations" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.LocationOn">@L["nav.storageLocations"]</MudNavLink>
        <MudNavLink Href="/settings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Tune">@L["nav.settings"]</MudNavLink>
    </MudNavGroup>
</MudNavMenu>

@* Upgrade banner dialog *@
<UpgradeBanner @ref="_upgradeBanner" />

@code {
    private bool _groceriesExpanded;
    private bool _householdExpanded;
    private bool _systemExpanded;
    private bool _initialized;
    private UpgradeBanner? _upgradeBanner;

    protected override async Task OnInitializedAsync()
    {
        await LoadExpandedStateAsync();
        _initialized = true;
    }

    private RenderFragment GatedNavLink(string href, string icon, string text, string featureArea) => builder =>
    {
        if (SubscriptionState.IsFeatureAvailable(featureArea))
        {
            builder.OpenComponent<MudNavLink>(0);
            builder.AddAttribute(1, "Href", href);
            builder.AddAttribute(2, "Match", NavLinkMatch.Prefix);
            builder.AddAttribute(3, "Icon", icon);
            builder.AddAttribute(4, "ChildContent", (RenderFragment)(b => b.AddContent(0, text)));
            builder.CloseComponent();
        }
        else
        {
            builder.OpenComponent<MudNavLink>(0);
            builder.AddAttribute(1, "Icon", icon);
            builder.AddAttribute(2, "OnClick", EventCallback.Factory.Create(this, () => ShowUpgrade(featureArea)));
            builder.AddAttribute(3, "Class", "locked-nav-item");
            builder.AddAttribute(4, "ChildContent", (RenderFragment)(b =>
            {
                b.AddContent(0, text + " ");
                b.OpenComponent<MudIcon>(1);
                b.AddAttribute(2, "Icon", Icons.Material.Filled.Lock);
                b.AddAttribute(3, "Size", Size.Small);
                b.AddAttribute(4, "Class", "ml-1");
                b.CloseComponent();
            }));
            builder.CloseComponent();
        }
    };

    private void ShowUpgrade(string featureArea)
    {
        _upgradeBanner?.Show(featureArea);
    }

    private async Task LoadExpandedStateAsync()
    {
        var expandedGroups = await NavMenuStorage.GetExpandedGroupsAsync();
        _groceriesExpanded = expandedGroups.Contains("groceries");
        _householdExpanded = expandedGroups.Contains("household");
        _systemExpanded = expandedGroups.Contains("system");
    }

    private async Task OnExpandedChanged(string groupName, bool isExpanded)
    {
        switch (groupName)
        {
            case "groceries":
                _groceriesExpanded = isExpanded;
                break;
            case "household":
                _householdExpanded = isExpanded;
                break;
            case "system":
                _systemExpanded = isExpanded;
                break;
        }

        if (_initialized)
        {
            await NavMenuStorage.ToggleGroupAsync(groupName, isExpanded);
        }
    }
}
