@inject IApiClient ApiClient
@inject ISnackbar Snackbar
@inject ILocalizer L
@using Famick.HomeManagement.Core.DTOs.MealPlanner

<MudPaper Elevation="1" Class="pa-4">
    <MudText Typo="Typo.h6" Class="mb-3">@L["mealPlanner.dietary.title"]</MudText>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_profile != null)
    {
        <MudStack Spacing="3">
            @* Allergens *@
            <MudText Typo="Typo.subtitle1">@L["mealPlanner.dietary.allergens"]</MudText>
            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                @foreach (var allergenType in Enum.GetValues<AllergenType>())
                {
                    var isSelected = _selectedAllergens.ContainsKey(allergenType);
                    <MudChip T="string" Color="@(isSelected ? Color.Error : Color.Default)"
                             Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                             OnClick="@(() => ToggleAllergen(allergenType))"
                             Disabled="@(!CanEdit)">
                        @GetAllergenName(allergenType)
                        @if (isSelected)
                        {
                            <MudText Typo="Typo.caption" Class="ml-1">
                                (@(_selectedAllergens[allergenType] == AllergenSeverity.Allergy
                                    ? L["mealPlanner.dietary.severity.allergy"]
                                    : L["mealPlanner.dietary.severity.sensitivity"]))
                            </MudText>
                        }
                    </MudChip>
                }
            </MudStack>

            @* Dietary Preferences *@
            <MudText Typo="Typo.subtitle1" Class="mt-2">@L["mealPlanner.dietary.preferences"]</MudText>
            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                @foreach (var pref in Enum.GetValues<DietaryPreference>())
                {
                    var isSelected = _selectedPreferences.Contains(pref);
                    <MudChip T="string" Color="@(isSelected ? Color.Primary : Color.Default)"
                             Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                             OnClick="@(() => TogglePreference(pref))"
                             Disabled="@(!CanEdit)">
                        @GetPreferenceName(pref)
                    </MudChip>
                }
            </MudStack>

            @* Notes *@
            <MudTextField @bind-Value="_dietaryNotes"
                          Label="@L["mealPlanner.dietary.notes"]"
                          Placeholder="@L["mealPlanner.dietary.notesPlaceholder"]"
                          Variant="Variant.Outlined"
                          Lines="2"
                          ReadOnly="@(!CanEdit)" />

            @if (CanEdit)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@_isSaving">
                    @L["common.save"]
                </MudButton>
            }
        </MudStack>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public Guid ContactId { get; set; }

    [CascadingParameter(Name = "CanEdit")]
    private bool CanEdit { get; set; }

    private bool _isLoading = true;
    private bool _isSaving;
    private DietaryProfileDto? _profile;
    private Dictionary<AllergenType, AllergenSeverity> _selectedAllergens = new();
    private HashSet<DietaryPreference> _selectedPreferences = new();
    private string? _dietaryNotes;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            var result = await ApiClient.GetAsync<DietaryProfileDto>($"api/v1/contacts/{ContactId}/dietary-profile");
            if (result.IsSuccess && result.Data != null)
            {
                _profile = result.Data;
                _selectedAllergens = _profile.Allergens.ToDictionary(a => a.AllergenType, a => a.Severity);
                _selectedPreferences = new HashSet<DietaryPreference>(_profile.DietaryPreferences.Select(p => p.DietaryPreference));
                _dietaryNotes = _profile.DietaryNotes;
            }
        }
        catch { }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleAllergen(AllergenType type)
    {
        if (!CanEdit) return;

        if (_selectedAllergens.ContainsKey(type))
        {
            if (_selectedAllergens[type] == AllergenSeverity.Sensitivity)
                _selectedAllergens[type] = AllergenSeverity.Allergy;
            else
                _selectedAllergens.Remove(type);
        }
        else
        {
            _selectedAllergens[type] = AllergenSeverity.Sensitivity;
        }
    }

    private void TogglePreference(DietaryPreference pref)
    {
        if (!CanEdit) return;

        if (!_selectedPreferences.Remove(pref))
            _selectedPreferences.Add(pref);
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        try
        {
            var request = new UpdateDietaryProfileRequest
            {
                DietaryNotes = _dietaryNotes,
                Allergens = _selectedAllergens.Select(kv => new UpdateContactAllergenRequest
                {
                    AllergenType = kv.Key,
                    Severity = kv.Value
                }).ToList(),
                DietaryPreferences = _selectedPreferences.ToList()
            };

            var result = await ApiClient.PutAsync<UpdateDietaryProfileRequest, DietaryProfileDto>(
                $"api/v1/contacts/{ContactId}/dietary-profile", request);

            if (result.IsSuccess)
                Snackbar.Add(L["common.saved"], Severity.Success);
            else
                Snackbar.Add(result.ErrorMessage ?? L["common.error"], Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private string GetAllergenName(AllergenType type) => type switch
    {
        AllergenType.Milk => L["mealPlanner.dietary.allergenTypes.milk"],
        AllergenType.Eggs => L["mealPlanner.dietary.allergenTypes.eggs"],
        AllergenType.Fish => L["mealPlanner.dietary.allergenTypes.fish"],
        AllergenType.Shellfish => L["mealPlanner.dietary.allergenTypes.shellfish"],
        AllergenType.TreeNuts => L["mealPlanner.dietary.allergenTypes.treeNuts"],
        AllergenType.Peanuts => L["mealPlanner.dietary.allergenTypes.peanuts"],
        AllergenType.Wheat => L["mealPlanner.dietary.allergenTypes.wheat"],
        AllergenType.Soybeans => L["mealPlanner.dietary.allergenTypes.soybeans"],
        AllergenType.Sesame => L["mealPlanner.dietary.allergenTypes.sesame"],
        AllergenType.Mustard => L["mealPlanner.dietary.allergenTypes.mustard"],
        AllergenType.Celery => L["mealPlanner.dietary.allergenTypes.celery"],
        AllergenType.Lupin => L["mealPlanner.dietary.allergenTypes.lupin"],
        AllergenType.Sulfites => L["mealPlanner.dietary.allergenTypes.sulfites"],
        AllergenType.Corn => L["mealPlanner.dietary.allergenTypes.corn"],
        AllergenType.Gluten => L["mealPlanner.dietary.allergenTypes.gluten"],
        AllergenType.Mollusks => L["mealPlanner.dietary.allergenTypes.mollusks"],
        _ => type.ToString()
    };

    private string GetPreferenceName(DietaryPreference pref) => pref switch
    {
        DietaryPreference.Vegetarian => L["mealPlanner.dietary.dietaryPreferences.vegetarian"],
        DietaryPreference.Vegan => L["mealPlanner.dietary.dietaryPreferences.vegan"],
        DietaryPreference.Pescatarian => L["mealPlanner.dietary.dietaryPreferences.pescatarian"],
        DietaryPreference.GlutenFree => L["mealPlanner.dietary.dietaryPreferences.glutenFree"],
        DietaryPreference.DairyFree => L["mealPlanner.dietary.dietaryPreferences.dairyFree"],
        DietaryPreference.NutFree => L["mealPlanner.dietary.dietaryPreferences.nutFree"],
        DietaryPreference.Halal => L["mealPlanner.dietary.dietaryPreferences.halal"],
        DietaryPreference.Kosher => L["mealPlanner.dietary.dietaryPreferences.kosher"],
        DietaryPreference.LowSodium => L["mealPlanner.dietary.dietaryPreferences.lowSodium"],
        DietaryPreference.LowCarb => L["mealPlanner.dietary.dietaryPreferences.lowCarb"],
        DietaryPreference.Keto => L["mealPlanner.dietary.dietaryPreferences.keto"],
        DietaryPreference.Paleo => L["mealPlanner.dietary.dietaryPreferences.paleo"],
        _ => pref.ToString()
    };
}
