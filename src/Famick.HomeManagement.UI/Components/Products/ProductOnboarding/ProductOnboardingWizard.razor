@inject IApiClient ApiClient
@inject ISnackbar Snackbar
@inject ILocalizer L
@inject NavigationManager Navigation
@using Famick.HomeManagement.Core.DTOs.ProductOnboarding
@using Famick.HomeManagement.Domain.Enums

<MudPaper Elevation="2" Class="pa-6" MaxWidth="900px" Style="margin: 0 auto;">
    <MudStepper @bind-ActiveIndex="_currentStep" NonLinear="false">
        <MudStep Title="@L["productOnboarding.household.title"]" />
        <MudStep Title="@L["productOnboarding.dietary.title"]" />
        <MudStep Title="@L["productOnboarding.cookingStyle.title"]" />
        <MudStep Title="@L["productOnboarding.review.title"]" />
        <MudStep Title="@L["productOnboarding.complete.title"]" />
    </MudStepper>

    <MudDivider Class="my-4" />

    @switch (_currentStep)
    {
        case 0:
            @* Step 1: Household Composition *@
            <MudStack Spacing="3">
                <MudText Typo="Typo.h5">@L["productOnboarding.household.title"]</MudText>
                <MudText>@L["productOnboarding.household.description"]</MudText>
                <MudSwitch @bind-Value="_answers.HasBaby" Label="@L["productOnboarding.household.hasBaby"]" Color="Color.Primary" />
                <MudSwitch @bind-Value="_answers.HasPets" Label="@L["productOnboarding.household.hasPets"]" Color="Color.Primary" />
                <MudSwitch @bind-Value="_answers.TrackHouseholdSupplies" Label="@L["productOnboarding.household.trackHousehold"]" Color="Color.Primary" />
                <MudSwitch @bind-Value="_answers.TrackPersonalCare" Label="@L["productOnboarding.household.trackPersonalCare"]" Color="Color.Primary" />
                <MudSwitch @bind-Value="_answers.TrackPharmacy" Label="@L["productOnboarding.household.trackPharmacy"]" Color="Color.Primary" />
            </MudStack>
            break;

        case 1:
            @* Step 2: Dietary Preferences & Allergens *@
            <MudStack Spacing="4">
                <MudText Typo="Typo.h5">@L["productOnboarding.dietary.title"]</MudText>
                <MudText>@L["productOnboarding.dietary.description"]</MudText>

                <MudText Typo="Typo.subtitle1" Class="mt-2">@L["productOnboarding.dietary.preferencesLabel"]</MudText>
                <MudChipSet T="DietaryPreference" MultiSelection="true" SelectedValues="_selectedDietaryPreferences" SelectedValuesChanged="OnDietaryPreferencesChanged">
                    @foreach (var pref in Enum.GetValues<DietaryPreference>())
                    {
                        <MudChip T="DietaryPreference" Value="pref" Variant="Variant.Outlined" Color="Color.Primary">
                            @FormatEnumName(pref.ToString())
                        </MudChip>
                    }
                </MudChipSet>

                <MudText Typo="Typo.subtitle1" Class="mt-2">@L["productOnboarding.dietary.allergensLabel"]</MudText>
                <MudChipSet T="AllergenType" MultiSelection="true" SelectedValues="_selectedAllergens" SelectedValuesChanged="OnAllergensChanged">
                    @foreach (var allergen in Enum.GetValues<AllergenType>())
                    {
                        <MudChip T="AllergenType" Value="allergen" Variant="Variant.Outlined" Color="Color.Warning">
                            @FormatEnumName(allergen.ToString())
                        </MudChip>
                    }
                </MudChipSet>
            </MudStack>
            break;

        case 2:
            @* Step 3: Cooking & Shopping Style *@
            <MudStack Spacing="3">
                <MudText Typo="Typo.h5">@L["productOnboarding.cookingStyle.title"]</MudText>
                <MudText>@L["productOnboarding.cookingStyle.description"]</MudText>
                <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="SelectAllCookingStyles" Class="align-self-start">
                    @L["productOnboarding.cookingStyle.selectAll"]
                </MudButton>
                <MudGrid Spacing="3">
                    @foreach (var style in Enum.GetValues<CookingStyleInterest>())
                    {
                        var isSelected = _answers.CookingStyles.Contains(style);
                        <MudItem xs="6" sm="4" md="3">
                            <MudCard Elevation="@(isSelected ? 3 : 1)"
                                     Style="@(isSelected ? "border: 2px solid var(--mud-palette-primary); cursor: pointer;" : "cursor: pointer;")"
                                     @onclick="@(() => ToggleCookingStyle(style))">
                                <MudCardContent Class="text-center pa-3">
                                    <MudIcon Icon="@GetCookingStyleIcon(style)" Size="Size.Large"
                                             Color="@(isSelected ? Color.Primary : Color.Default)" />
                                    <MudText Typo="Typo.body2" Class="mt-1">@GetCookingStyleLabel(style)</MudText>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            </MudStack>
            break;

        case 3:
            @* Step 4: Review & Confirm *@
            <MudStack Spacing="3">
                <MudText Typo="Typo.h5">@L["productOnboarding.review.title"]</MudText>
                @if (_isLoadingPreview)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                    <MudText Color="Color.Secondary">@L["productOnboarding.review.loading"]</MudText>
                }
                else if (_previewResponse != null)
                {
                    <MudText Typo="Typo.subtitle1">
                        @string.Format(L["productOnboarding.review.summary"], _selectedMasterProductIds.Count, _previewResponse.Categories.Count)
                    </MudText>

                    @foreach (var category in _previewResponse.Categories)
                    {
                        var categorySelectedCount = category.Items.Count(i => _selectedMasterProductIds.Contains(i.Id));
                        var allSelected = categorySelectedCount == category.Items.Count;
                        <MudExpansionPanel Text="@($"{category.Category} ({categorySelectedCount}/{category.Items.Count})")"
                                           IsInitiallyExpanded="@(category.Items.Count < 10)">
                            <MudStack Spacing="1">
                                <MudCheckBox T="bool" Value="allSelected"
                                             ValueChanged="@((bool v) => ToggleCategoryAll(category, v))"
                                             Label="@L["common.selectAll"]"
                                             Dense="true" Color="Color.Primary" />
                                <MudDivider Class="my-1" />
                                @foreach (var item in category.Items)
                                {
                                    var itemSelected = _selectedMasterProductIds.Contains(item.Id);
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudCheckBox T="bool" Value="itemSelected"
                                                     ValueChanged="@((bool v) => ToggleMasterProduct(item.Id, v))"
                                                     Dense="true" Color="Color.Primary" />
                                        <MudText>@item.Name</MudText>
                                        @if (!string.IsNullOrEmpty(item.ContainerType))
                                        {
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@item.ContainerType</MudChip>
                                        }
                                    </MudStack>
                                }
                            </MudStack>
                        </MudExpansionPanel>
                    }
                }
            </MudStack>
            break;

        case 4:
            @* Step 5: Completion *@
            <MudStack Spacing="3" AlignItems="AlignItems.Center">
                @if (_isCompleting)
                {
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    <MudText>@L["productOnboarding.complete.creating"]</MudText>
                }
                else if (_completeResponse != null)
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" />
                    <MudText Typo="Typo.h5">@L["productOnboarding.complete.title"]</MudText>
                    <MudText>@string.Format(L["productOnboarding.complete.created"], _completeResponse.ProductsCreated)</MudText>
                    @if (_completeResponse.ProductsSkipped > 0)
                    {
                        <MudText Color="Color.Secondary">
                            @string.Format(L["productOnboarding.complete.skipped"], _completeResponse.ProductsSkipped)
                        </MudText>
                    }
                    <MudStack Row="true" Spacing="3" Class="mt-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToProducts">
                            @L["productOnboarding.complete.goToProducts"]
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" OnClick="FinishOnboarding">
                            @L["common.done"]
                        </MudButton>
                    </MudStack>
                }
            </MudStack>
            break;
    }

    @if (_currentStep < 4)
    {
        <MudDivider Class="my-4" />

        <MudStack Row="true" Justify="Justify.SpaceBetween">
            @if (_currentStep > 0)
            {
                <MudButton Variant="Variant.Outlined" OnClick="PreviousStep">@L["common.back"]</MudButton>
            }
            else
            {
                <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="SkipOnboarding">
                    @L["productOnboarding.skip"]
                </MudButton>
            }
            <MudSpacer />
            @if (_currentStep < 3)
            {
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="SkipStep">@L["common.skip"]</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextStep">@L["common.next"]</MudButton>
                </MudStack>
            }
            else
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Disabled="@(_selectedMasterProductIds.Count == 0 || _isLoadingPreview)"
                           OnClick="CreateProducts">
                    @L["productOnboarding.review.createProducts"]
                </MudButton>
            }
        </MudStack>
    }
</MudPaper>

@code {
    [Parameter]
    public EventCallback OnComplete { get; set; }

    [Parameter]
    public ProductOnboardingAnswersDto? PrePopulatedAnswers { get; set; }

    private int _currentStep;
    private ProductOnboardingAnswersDto _answers = new();
    private IReadOnlyCollection<DietaryPreference> _selectedDietaryPreferences = Array.Empty<DietaryPreference>();
    private IReadOnlyCollection<AllergenType> _selectedAllergens = Array.Empty<AllergenType>();

    // Review step state
    private bool _isLoadingPreview;
    private ProductOnboardingPreviewResponse? _previewResponse;
    private HashSet<Guid> _selectedMasterProductIds = new();

    // Completion state
    private bool _isCompleting;
    private ProductOnboardingCompleteResponse? _completeResponse;

    protected override void OnInitialized()
    {
        if (PrePopulatedAnswers != null)
        {
            _answers = PrePopulatedAnswers;
            _selectedDietaryPreferences = _answers.DietaryPreferences.ToArray();
            _selectedAllergens = _answers.Allergens.ToArray();
        }
    }

    private void NextStep()
    {
        if (_currentStep < 4)
        {
            _currentStep++;
            if (_currentStep == 3)
                _ = LoadPreviewAsync();
        }
    }

    private void SkipStep()
    {
        NextStep();
    }

    private void PreviousStep()
    {
        if (_currentStep > 0)
            _currentStep--;
    }

    private async Task SkipOnboarding()
    {
        // Complete with empty selection (just mark as done)
        try
        {
            var request = new ProductOnboardingCompleteRequest
            {
                Answers = _answers,
                SelectedMasterProductIds = new List<Guid>()
            };
            await ApiClient.PostAsync<ProductOnboardingCompleteRequest, ProductOnboardingCompleteResponse>(
                "api/v1/product-onboarding/complete", request);
        }
        catch { }

        await OnComplete.InvokeAsync();
    }

    private async Task LoadPreviewAsync()
    {
        _isLoadingPreview = true;
        StateHasChanged();

        try
        {
            var result = await ApiClient.PostAsync<ProductOnboardingAnswersDto, ProductOnboardingPreviewResponse>(
                "api/v1/product-onboarding/preview", _answers);

            if (result.IsSuccess && result.Data != null)
            {
                _previewResponse = result.Data;
                _selectedMasterProductIds = _previewResponse.Categories
                    .SelectMany(c => c.Items)
                    .Select(i => i.Id)
                    .ToHashSet();
            }
            else
            {
                Snackbar.Add("Failed to load product suggestions", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isLoadingPreview = false;
            StateHasChanged();
        }
    }

    private async Task CreateProducts()
    {
        _currentStep = 4;
        _isCompleting = true;
        StateHasChanged();

        try
        {
            var request = new ProductOnboardingCompleteRequest
            {
                Answers = _answers,
                SelectedMasterProductIds = _selectedMasterProductIds.ToList()
            };

            var result = await ApiClient.PostAsync<ProductOnboardingCompleteRequest, ProductOnboardingCompleteResponse>(
                "api/v1/product-onboarding/complete", request);

            if (result.IsSuccess && result.Data != null)
            {
                _completeResponse = result.Data;
            }
            else
            {
                Snackbar.Add("Failed to create products", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isCompleting = false;
            StateHasChanged();
        }
    }

    private void GoToProducts()
    {
        Navigation.NavigateTo("/products", forceLoad: true);
    }

    private async Task FinishOnboarding()
    {
        await OnComplete.InvokeAsync();
    }

    private void OnDietaryPreferencesChanged(IReadOnlyCollection<DietaryPreference> values)
    {
        _selectedDietaryPreferences = values;
        _answers.DietaryPreferences = values.ToList();
    }

    private void OnAllergensChanged(IReadOnlyCollection<AllergenType> values)
    {
        _selectedAllergens = values;
        _answers.Allergens = values.ToList();
    }

    private void ToggleCookingStyle(CookingStyleInterest style)
    {
        if (_answers.CookingStyles.Contains(style))
            _answers.CookingStyles.Remove(style);
        else
            _answers.CookingStyles.Add(style);
    }

    private void SelectAllCookingStyles()
    {
        _answers.CookingStyles = Enum.GetValues<CookingStyleInterest>().ToList();
    }

    private void ToggleMasterProduct(Guid id, bool selected)
    {
        if (selected)
            _selectedMasterProductIds.Add(id);
        else
            _selectedMasterProductIds.Remove(id);
    }

    private void ToggleCategoryAll(MasterProductCategoryGroup category, bool selectAll)
    {
        foreach (var item in category.Items)
        {
            if (selectAll)
                _selectedMasterProductIds.Add(item.Id);
            else
                _selectedMasterProductIds.Remove(item.Id);
        }
    }

    private static string FormatEnumName(string name)
    {
        // Insert spaces before capital letters: "GlutenFree" -> "Gluten Free"
        return System.Text.RegularExpressions.Regex.Replace(name, "(?<!^)([A-Z])", " $1");
    }

    private static string GetCookingStyleIcon(CookingStyleInterest style) => style switch
    {
        CookingStyleInterest.FreshProduce => Icons.Material.Filled.Grass,
        CookingStyleInterest.DairyAndEggs => Icons.Material.Filled.EggAlt,
        CookingStyleInterest.MeatAndSeafood => Icons.Material.Filled.SetMeal,
        CookingStyleInterest.Baking => Icons.Material.Filled.Cake,
        CookingStyleInterest.InternationalFoods => Icons.Material.Filled.Public,
        CookingStyleInterest.FrozenFoods => Icons.Material.Filled.AcUnit,
        CookingStyleInterest.BreakfastStaples => Icons.Material.Filled.FreeBreakfast,
        CookingStyleInterest.CannedGoodsAndMealPrep => Icons.Material.Filled.Inventory2,
        CookingStyleInterest.Beverages => Icons.Material.Filled.LocalDrink,
        CookingStyleInterest.CondimentsAndPantry => Icons.Material.Filled.Kitchen,
        _ => Icons.Material.Filled.ShoppingCart
    };

    private string GetCookingStyleLabel(CookingStyleInterest style) => style switch
    {
        CookingStyleInterest.FreshProduce => L["productOnboarding.cookingStyle.freshProduce"],
        CookingStyleInterest.DairyAndEggs => L["productOnboarding.cookingStyle.dairyAndEggs"],
        CookingStyleInterest.MeatAndSeafood => L["productOnboarding.cookingStyle.meatAndSeafood"],
        CookingStyleInterest.Baking => L["productOnboarding.cookingStyle.baking"],
        CookingStyleInterest.InternationalFoods => L["productOnboarding.cookingStyle.internationalFoods"],
        CookingStyleInterest.FrozenFoods => L["productOnboarding.cookingStyle.frozenFoods"],
        CookingStyleInterest.BreakfastStaples => L["productOnboarding.cookingStyle.breakfastStaples"],
        CookingStyleInterest.CannedGoodsAndMealPrep => L["productOnboarding.cookingStyle.cannedGoods"],
        CookingStyleInterest.Beverages => L["productOnboarding.cookingStyle.beverages"],
        CookingStyleInterest.CondimentsAndPantry => L["productOnboarding.cookingStyle.condimentsAndPantry"],
        _ => style.ToString()
    };
}
