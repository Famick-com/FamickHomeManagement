@inject IApiClient ApiClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILocalizer L
@using Famick.HomeManagement.Core.DTOs.MealPlanner
@using MudBlazor.Utilities

<MudPaper Elevation="1" Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudText Typo="Typo.h6">@L["mealPlanner.mealTypes.title"]</MudText>
        @if (CanEdit)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateDialog"
                       Disabled="@(_mealTypes.Count >= 10)">
                @L["mealPlanner.mealTypes.add"]
            </MudButton>
        }
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudList T="MealTypeDto" Dense="true">
            @foreach (var mealType in _mealTypes.OrderBy(mt => mt.SortOrder))
            {
                <MudListItem>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        @if (!string.IsNullOrEmpty(mealType.Color))
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small"
                                     Style="@($"color: {mealType.Color};")" />
                        }
                        <MudText>@mealType.Name</MudText>
                        @if (mealType.IsDefault)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@L["mealPlanner.mealTypes.isDefault"]</MudChip>
                        }
                        <MudSpacer />
                        @if (CanEdit)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => OpenEditDialog(mealType))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => DeleteAsync(mealType))"
                                           Disabled="@mealType.IsDefault" />
                        }
                    </MudStack>
                </MudListItem>
            }
        </MudList>
    }
</MudPaper>

@* Inline edit dialog *@
<MudDialog @bind-Visible="_editDialogVisible" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_isEditing ? L["mealPlanner.mealTypes.edit"] : L["mealPlanner.mealTypes.add"])</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_editName" Label="@L["mealPlanner.mealTypes.name"]" Variant="Variant.Outlined" />
            <MudColorPicker @bind-Value="_editColor" Label="@L["mealPlanner.mealTypes.color"]" Variant="Variant.Outlined" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _editDialogVisible = false)">@L["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveMealTypeAsync">@L["common.save"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter(Name = "CanEdit")]
    private bool CanEdit { get; set; }

    private bool _isLoading = true;
    private List<MealTypeDto> _mealTypes = new();
    private bool _editDialogVisible;
    private bool _isEditing;
    private Guid? _editId;
    private string _editName = string.Empty;
    private MudColor _editColor = new("#4CAF50");

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            var result = await ApiClient.GetAsync<List<MealTypeDto>>("api/v1/meal-types");
            if (result.IsSuccess && result.Data != null)
                _mealTypes = result.Data;
        }
        catch { }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenCreateDialog()
    {
        _isEditing = false;
        _editId = null;
        _editName = string.Empty;
        _editColor = new MudColor("#4CAF50");
        _editDialogVisible = true;
    }

    private void OpenEditDialog(MealTypeDto mealType)
    {
        _isEditing = true;
        _editId = mealType.Id;
        _editName = mealType.Name;
        _editColor = new MudColor(mealType.Color ?? "#4CAF50");
        _editDialogVisible = true;
    }

    private async Task SaveMealTypeAsync()
    {
        if (string.IsNullOrWhiteSpace(_editName)) return;

        if (_isEditing && _editId.HasValue)
        {
            var request = new UpdateMealTypeRequest { Name = _editName, Color = _editColor.ToString() };
            var result = await ApiClient.PutAsync<UpdateMealTypeRequest, MealTypeDto>($"api/v1/meal-types/{_editId.Value}", request);
            if (!result.IsSuccess)
            {
                Snackbar.Add(result.ErrorMessage ?? L["common.error"], Severity.Error);
                return;
            }
        }
        else
        {
            var request = new CreateMealTypeRequest { Name = _editName, Color = _editColor.ToString() };
            var result = await ApiClient.PostAsync<CreateMealTypeRequest, MealTypeDto>("api/v1/meal-types", request);
            if (!result.IsSuccess)
            {
                Snackbar.Add(result.ErrorMessage ?? L["common.error"], Severity.Error);
                return;
            }
        }

        Snackbar.Add(L["mealPlanner.mealTypes.saved"], Severity.Success);
        _editDialogVisible = false;
        await LoadAsync();
    }

    private async Task DeleteAsync(MealTypeDto mealType)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["confirmations.deleteTitle"],
            L["mealPlanner.mealTypes.confirmDelete"],
            yesText: L["common.delete"],
            cancelText: L["common.cancel"]);

        if (confirmed != true) return;

        var result = await ApiClient.DeleteAsync($"api/v1/meal-types/{mealType.Id}");
        if (result.IsSuccess)
        {
            Snackbar.Add(L["mealPlanner.mealTypes.deleted"], Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.ErrorMessage ?? L["common.error"], Severity.Error);
        }
    }
}
