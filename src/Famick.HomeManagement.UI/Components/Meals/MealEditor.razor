@inject IApiClient ApiClient
@inject ISnackbar Snackbar
@inject ILocalizer L
@using Famick.HomeManagement.Core.DTOs.MealPlanner

<MudDialog @bind-Visible="_isVisible" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_isEdit ? L["mealPlanner.meals.edit"] : L["mealPlanner.meals.add"])</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_name"
                          Label="@L["mealPlanner.meals.name"]"
                          Variant="Variant.Outlined"
                          Required="true" />

            <MudTextField @bind-Value="_notes"
                          Label="@L["common.notes"]"
                          Variant="Variant.Outlined"
                          Lines="3" />

            <MudSwitch @bind-Value="_isFavorite"
                       Label="@L["mealPlanner.meals.favorite"]"
                       Color="Color.Error" />

            @* Items section *@
            <MudText Typo="Typo.subtitle1" Class="mt-2">@L["mealPlanner.meals.items"]</MudText>

            @for (int i = 0; i < _items.Count; i++)
            {
                var index = i;
                <MudPaper Elevation="0" Class="pa-3" Style="border: 1px solid var(--mud-palette-lines-default);">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudSelect T="MealItemType" @bind-Value="_items[index].ItemType"
                                       Label="Type" Variant="Variant.Outlined" Margin="Margin.Dense"
                                       Style="max-width: 150px;">
                                <MudSelectItem T="MealItemType" Value="MealItemType.Recipe">@L["mealPlanner.meals.itemType.recipe"]</MudSelectItem>
                                <MudSelectItem T="MealItemType" Value="MealItemType.Product">@L["mealPlanner.meals.itemType.product"]</MudSelectItem>
                                <MudSelectItem T="MealItemType" Value="MealItemType.Freetext">@L["mealPlanner.meals.itemType.freetext"]</MudSelectItem>
                            </MudSelect>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => RemoveItem(index))" />
                        </MudStack>

                        @if (_items[index].ItemType == MealItemType.Freetext)
                        {
                            <MudTextField @bind-Value="_items[index].FreetextDescription"
                                          Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        }
                        else if (_items[index].ItemType == MealItemType.Product)
                        {
                            <MudAutocomplete T="ProductOption" @bind-Value="_items[index].SelectedProduct"
                                             Label="Product" Variant="Variant.Outlined" Margin="Margin.Dense"
                                             SearchFunc="SearchProducts" ToStringFunc="@(p => p?.Name ?? "")"
                                             Dense="true" />
                            <MudStack Row="true" Spacing="2">
                                <MudNumericField T="decimal?" @bind-Value="_items[index].ProductQuantity"
                                                 Label="@L["common.quantity"]" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Min="0" />
                            </MudStack>
                        }
                        else if (_items[index].ItemType == MealItemType.Recipe)
                        {
                            <MudAutocomplete T="RecipeOption" @bind-Value="_items[index].SelectedRecipe"
                                             Label="Recipe" Variant="Variant.Outlined" Margin="Margin.Dense"
                                             SearchFunc="SearchRecipes" ToStringFunc="@(r => r?.Name ?? "")"
                                             Dense="true" />
                        }
                    </MudStack>
                </MudPaper>
            }

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="AddItem"
                       FullWidth="true">
                @L["mealPlanner.meals.addItem"]
            </MudButton>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">@L["common.cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@_isSaving">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @L["common.save"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public EventCallback OnSaved { get; set; }

    private bool _isVisible;
    private bool _isEdit;
    private bool _isSaving;
    private Guid? _editId;
    private string _name = string.Empty;
    private string? _notes;
    private bool _isFavorite;
    private List<MealItemEditorModel> _items = new();

    public async Task OpenCreateAsync()
    {
        _isEdit = false;
        _editId = null;
        _name = string.Empty;
        _notes = null;
        _isFavorite = false;
        _items = new List<MealItemEditorModel>();
        _isVisible = true;
        await Task.CompletedTask;
    }

    public async Task OpenEditAsync(Guid id)
    {
        _isEdit = true;
        _editId = id;

        var result = await ApiClient.GetAsync<MealDto>($"api/v1/meals/{id}");
        if (result.IsSuccess && result.Data != null)
        {
            _name = result.Data.Name;
            _notes = result.Data.Notes;
            _isFavorite = result.Data.IsFavorite;
            _items = result.Data.Items.Select(i => new MealItemEditorModel
            {
                ItemType = i.ItemType,
                FreetextDescription = i.FreetextDescription,
                ProductQuantity = i.ProductQuantity,
                SelectedProduct = i.ProductId.HasValue ? new ProductOption { Id = i.ProductId.Value, Name = i.ProductName ?? "" } : null,
                SelectedRecipe = i.RecipeId.HasValue ? new RecipeOption { Id = i.RecipeId.Value, Name = i.RecipeName ?? "" } : null,
                SortOrder = i.SortOrder
            }).ToList();
        }
        _isVisible = true;
    }

    private void Close()
    {
        _isVisible = false;
    }

    private void AddItem()
    {
        _items.Add(new MealItemEditorModel { ItemType = MealItemType.Product, SortOrder = _items.Count });
    }

    private void RemoveItem(int index)
    {
        _items.RemoveAt(index);
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;

        _isSaving = true;
        try
        {
            var items = _items.Select((item, idx) => new CreateMealItemRequest
            {
                ItemType = item.ItemType,
                RecipeId = item.ItemType == MealItemType.Recipe ? item.SelectedRecipe?.Id : null,
                ProductId = item.ItemType == MealItemType.Product ? item.SelectedProduct?.Id : null,
                ProductQuantity = item.ItemType == MealItemType.Product ? item.ProductQuantity : null,
                FreetextDescription = item.ItemType == MealItemType.Freetext ? item.FreetextDescription : null,
                SortOrder = idx
            }).ToList();

            if (_isEdit && _editId.HasValue)
            {
                var request = new UpdateMealRequest { Name = _name, Notes = _notes, IsFavorite = _isFavorite, Items = items };
                var result = await ApiClient.PutAsync<UpdateMealRequest, MealDto>($"api/v1/meals/{_editId.Value}", request);
                if (!result.IsSuccess)
                {
                    Snackbar.Add(result.ErrorMessage ?? L["common.error"], Severity.Error);
                    return;
                }
            }
            else
            {
                var request = new CreateMealRequest { Name = _name, Notes = _notes, IsFavorite = _isFavorite, Items = items };
                var result = await ApiClient.PostAsync<CreateMealRequest, MealDto>("api/v1/meals", request);
                if (!result.IsSuccess)
                {
                    Snackbar.Add(result.ErrorMessage ?? L["common.error"], Severity.Error);
                    return;
                }
            }

            Snackbar.Add(L["mealPlanner.meals.saved"], Severity.Success);
            _isVisible = false;
            await OnSaved.InvokeAsync();
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task<IEnumerable<ProductOption>> SearchProducts(string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value)) return Enumerable.Empty<ProductOption>();

        var result = await ApiClient.GetAsync<List<ProductOption>>($"api/v1/products/autocomplete?q={Uri.EscapeDataString(value)}");
        return result.IsSuccess && result.Data != null ? result.Data : Enumerable.Empty<ProductOption>();
    }

    private async Task<IEnumerable<RecipeOption>> SearchRecipes(string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value)) return Enumerable.Empty<RecipeOption>();

        var result = await ApiClient.GetAsync<List<RecipeOption>>($"api/v1/recipes?searchTerm={Uri.EscapeDataString(value)}");
        return result.IsSuccess && result.Data != null ? result.Data : Enumerable.Empty<RecipeOption>();
    }

    private class MealItemEditorModel
    {
        public MealItemType ItemType { get; set; }
        public string? FreetextDescription { get; set; }
        public decimal? ProductQuantity { get; set; }
        public ProductOption? SelectedProduct { get; set; }
        public RecipeOption? SelectedRecipe { get; set; }
        public int SortOrder { get; set; }
    }

    public class ProductOption
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }

    public class RecipeOption
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }
}
