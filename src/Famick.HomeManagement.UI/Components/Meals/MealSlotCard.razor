@inject ILocalizer L
@using Famick.HomeManagement.Core.DTOs.MealPlanner

<MudPaper Elevation="0" Class="pa-2 mb-1" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 4px;">
    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
        @if (Entry.MealId.HasValue)
        {
            <MudIcon Icon="@Icons.Material.Filled.LunchDining" Size="Size.Small" Color="Color.Secondary" />
            <MudStack Spacing="0" Class="flex-grow-1">
                <MudText Typo="Typo.body2">
                    @Entry.MealName
                    @if (Entry.IsBatchSource)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ml-1">@L["mealPlanner.plans.batchCooking"]</MudChip>
                    }
                    @if (Entry.BatchSourceEntryId.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="ml-1">@GetFromBatchLabel()</MudChip>
                    }
                </MudText>
                @foreach (var bci in Entry.BatchCookItems)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Class="mt-1" Style="font-size: 0.7rem;">
                        @string.Format(L["mealPlanner.plans.batch.batchItem"], bci.ProductName)
                    </MudChip>
                }
                @foreach (var usage in Entry.BatchCookItemUsages)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Class="mt-1" Style="font-size: 0.7rem;">
                        @string.Format(L["mealPlanner.plans.batch.usesFrom"], usage.DependentEntryMealName ?? "batch")
                    </MudChip>
                }
            </MudStack>
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Color="Color.Tertiary" />
            <MudText Typo="Typo.body2" Class="flex-grow-1" Style="font-style: italic;">@Entry.InlineNote</MudText>
        }

        @if (CanEdit)
        {
            @if (Entry.MealId.HasValue)
            {
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true">
                    <MudMenuItem OnClick="@(() => OnManageBatchItems.InvokeAsync())">
                        @L["mealPlanner.plans.batch.manageIngredients"]
                    </MudMenuItem>
                    @if (!Entry.BatchSourceEntryId.HasValue)
                    {
                        <MudMenuItem OnClick="@(() => OnBatchToggle.InvokeAsync(!Entry.IsBatchSource))">
                            @(Entry.IsBatchSource ? L["mealPlanner.plans.batch.unmark"] : L["mealPlanner.plans.markAsBatch"])
                        </MudMenuItem>
                    }
                    @if (Entry.BatchSourceEntryId.HasValue)
                    {
                        <MudMenuItem OnClick="@(() => OnUnlink.InvokeAsync())">
                            @L["mealPlanner.plans.batch.unlink"]
                        </MudMenuItem>
                    }
                    <MudMenuItem OnClick="@(() => OnDelete.InvokeAsync())" Style="color: var(--mud-palette-error);">
                        @L["common.delete"]
                    </MudMenuItem>
                </MudMenu>
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               Color="Color.Error"
                               OnClick="@(() => OnDelete.InvokeAsync())" />
            }
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public MealPlanEntryDto Entry { get; set; } = null!;

    [Parameter]
    public bool CanEdit { get; set; }

    [Parameter]
    public EventCallback OnDelete { get; set; }

    [Parameter]
    public EventCallback<bool> OnBatchToggle { get; set; }

    [Parameter]
    public EventCallback OnUnlink { get; set; }

    [Parameter]
    public EventCallback OnManageBatchItems { get; set; }

    [Parameter]
    public List<MealPlanEntryDto> AllEntries { get; set; } = new();

    private string GetFromBatchLabel()
    {
        if (!Entry.BatchSourceEntryId.HasValue) return L["mealPlanner.plans.fromBatch"];

        var source = AllEntries.FirstOrDefault(e => e.Id == Entry.BatchSourceEntryId.Value);
        if (source == null) return L["mealPlanner.plans.fromBatch"];

        var dayName = GetShortDayName(source.DayOfWeek);
        return string.Format(L["mealPlanner.plans.batch.fromDay"], dayName);
    }

    private string GetShortDayName(int dayOfWeek) => dayOfWeek switch
    {
        0 => "Mon",
        1 => "Tue",
        2 => "Wed",
        3 => "Thu",
        4 => "Fri",
        5 => "Sat",
        6 => "Sun",
        _ => ""
    };
}
