                                        </span>
                                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default" />
                                    </MudStack>
                                </MudListItem>
                                    }
                                </MudList>
                            </ChildContent>
                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>
                @if (_groupBy == "parentProduct" && _standaloneProducts.Any())
                {
                    <MudList T="ProductDto" Dense="true" Class="pa-0 mt-4">
                        @foreach (var product in _standaloneProducts)
                        {
                            var imgUrl2 = GetProductImageUrl(product);
                            <MudListItem T="ProductDto" OnClick="@(() => NavigateToProduct(product.Id))" Class="pa-2 rounded mb-1" Style="background: var(--mud-palette-surface);">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    @if (!string.IsNullOrEmpty(imgUrl2))
                                    {
                                        <MudImage Src="@imgUrl2"
                                                  Width="48" Height="48"
                                                  ObjectFit="ObjectFit.Cover"
                                                  Class="rounded"
                                                  Alt="@product.Name" />
                                    }
                                    else
                                    {
                                        <MudPaper Width="48px" Height="48px" Elevation="0" Class="d-flex align-center justify-center rounded" Style="background: var(--mud-palette-background-grey);">
                                            <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                                                     Size="Size.Medium"
                                                     Color="Color.Default"
                                                     Style="opacity: 0.4;" />
                                        </MudPaper>
                                    }
                                    <MudStack Spacing="0" Class="flex-grow-1 overflow-hidden">
                                        <MudText Typo="Typo.body1" Class="text-truncate" Style="font-weight: 500;">@product.Name</MudText>
                                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                            @if (product.TotalStockAmount > 0)
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @product.TotalStockAmount.ToString("0.##") @product.QuantityUnitStockName
                                                </MudText>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Warning">@L["stock.outOfStock"]</MudText>
                                            }
                                            @if (product.IsBelowMinStock && product.MinStockAmount > 0)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Class="ma-0 pa-1">@L["stock.belowMinStock"]</MudChip>
                                            }
                                            else if (!product.IsActive)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" Class="ma-0 pa-1">@L["products.inactive"]</MudChip>
                                            }
                                        </MudStack>
                                    </MudStack>
                                    <span @onclick:stopPropagation="true">
                                        <MudIconButton Icon="@Icons.Material.Filled.AddShoppingCart"
                                                       Size="Size.Small"
                                                       Color="Color.Primary"
                                                       OnClick="@(() => OpenAddToShoppingListDialog(product))" />
                                    </span>
                                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default" />
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                }
            }
            else
            {
                <MudList T="ProductDto" Dense="true" Class="pa-0">
                    @foreach (var product in _filteredProducts)
                    {
                        var imgUrl3 = GetProductImageUrl(product);
                        <MudListItem T="ProductDto" OnClick="@(() => NavigateToProduct(product.Id))" Class="pa-2 rounded mb-1" Style="background: var(--mud-palette-surface);">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                @if (!string.IsNullOrEmpty(imgUrl3))
                                {
                                    <MudImage Src="@imgUrl3"
                                              Width="48" Height="48"
                                              ObjectFit="ObjectFit.Cover"
                                              Class="rounded"
                                              Alt="@product.Name" />
                                }
                                else
                                {
                                    <MudPaper Width="48px" Height="48px" Elevation="0" Class="d-flex align-center justify-center rounded" Style="background: var(--mud-palette-background-grey);">
                                        <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                                                 Size="Size.Medium"
                                                 Color="Color.Default"
                                                 Style="opacity: 0.4;" />
                                    </MudPaper>
                                }
                                <MudStack Spacing="0" Class="flex-grow-1 overflow-hidden">
                                    <MudText Typo="Typo.body1" Class="text-truncate" Style="font-weight: 500;">@product.Name</MudText>
                                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                        @if (product.TotalStockAmount > 0)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @product.TotalStockAmount.ToString("0.##") @product.QuantityUnitStockName
                                            </MudText>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Warning">@L["stock.outOfStock"]</MudText>
                                        }
                                        @if (product.IsBelowMinStock && product.MinStockAmount > 0)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Class="ma-0 pa-1">@L["stock.belowMinStock"]</MudChip>
                                        }
                                        else if (!product.IsActive)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" Class="ma-0 pa-1">@L["products.inactive"]</MudChip>
                                        }
                                    </MudStack>
                                </MudStack>
                                <span @onclick:stopPropagation="true">
                                    <MudIconButton Icon="@Icons.Material.Filled.AddShoppingCart"
                                                   Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="@(() => OpenAddToShoppingListDialog(product))" />
                                </span>
                                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default" />
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>

                @if (_totalPages > 1)
                {
                    <div class="d-flex justify-center align-center pa-4">
                        <MudPagination Count="_totalPages"
                                       Selected="_currentPage"
                                       SelectedChanged="OnPageChanged"
                                       Color="Color.Primary"
                                       BoundaryCount="1"
                                       MiddleCount="3" />
                    </div>
                }
            }
        </MudHidden>
    }
</MudPaper>
}

@code {
    [CascadingParameter(Name = "CanEdit")]
    private bool CanEdit { get; set; }

    private bool _isCheckingOnboarding = true;
    private bool _showOnboarding;
    private ProductOnboardingAnswersDto? _savedAnswers;

    private List<ProductDto> _products = new();
    private bool _isLoading = true;
    private string _searchText = string.Empty;
    private string _statusFilter = "all";
    private string _groupBy = "parentProduct";

    private int _currentPage = 1;
    private int _totalPages = 1;
    private const int PageSize = 25;

    private IEnumerable<ProductDto> _filteredProducts => _groupBy == "none"
        ? _products
        : _products
            .Where(p => string.IsNullOrEmpty(_searchText) ||
                        p.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                        p.Barcodes.Any(b => b.Barcode.Contains(_searchText, StringComparison.OrdinalIgnoreCase)))
            .Where(p => _statusFilter == "all" ||
                        (_statusFilter == "active" && p.IsActive) ||
                        (_statusFilter == "inactive" && !p.IsActive));

    private HashSet<string> _parentProductNames => _filteredProducts
        .Where(p => !string.IsNullOrEmpty(p.ParentProductName))
        .Select(p => p.ParentProductName!)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);

    private IEnumerable<IGrouping<string, ProductDto>> _groupedProducts => _filteredProducts
        .Where(p => !string.IsNullOrEmpty(p.ParentProductName))
        .GroupBy(p => p.ParentProductName!)
        .OrderBy(g => g.Key);

    private IEnumerable<ProductDto> _standaloneProducts => _filteredProducts
        .Where(p => string.IsNullOrEmpty(p.ParentProductName) && !_parentProductNames.Contains(p.Name));

    private IEnumerable<IGrouping<string, ProductDto>> _groupedByProductGroup => _filteredProducts
        .GroupBy(p => p.ProductGroupName ?? "")
        .OrderBy(g => string.IsNullOrEmpty(g.Key) ? 1 : 0) // Groups with product groups first
        .ThenBy(g => g.Key);

    protected override async Task OnInitializedAsync()
    {
        await CheckOnboardingAsync();
    }

    private async Task CheckOnboardingAsync()
    {
        _isCheckingOnboarding = true;
        try
        {
            var result = await ApiClient.GetAsync<ProductOnboardingStateDto>("api/v1/product-onboarding");
            if (result.IsSuccess && result.Data != null)
            {
                _showOnboarding = !result.Data.HasCompletedOnboarding;
                _savedAnswers = result.Data.SavedAnswers;
            }
        }
        catch
        {
            // Proceed without onboarding on error
        }
        finally
        {
            _isCheckingOnboarding = false;
        }

        if (!_showOnboarding)
        {
            await LoadProductsAsync();
        }
    }

    private async Task OnOnboardingComplete()
    {
        _showOnboarding = false;
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        _isLoading = true;

        try
        {
            if (_groupBy == "none")
            {
                var queryParams = new List<string>
                {
                    $"page={_currentPage}",
                    $"pageSize={PageSize}"
                };
                if (!string.IsNullOrEmpty(_searchText))
                    queryParams.Add($"searchTerm={Uri.EscapeDataString(_searchText)}");
                if (_statusFilter == "active")
                    queryParams.Add("isActive=true");
                else if (_statusFilter == "inactive")
                    queryParams.Add("isActive=false");

                var url = $"api/v1/products?{string.Join("&", queryParams)}";
                var result = await ApiClient.GetAsync<PagedResult<ProductDto>>(url);
                if (result.IsSuccess && result.Data != null)
                {
                    _products = result.Data.Items;
                    _totalPages = result.Data.TotalPages;
                    _currentPage = result.Data.Page;
                }
                else
                {
                    Snackbar.Add(result.ErrorMessage ?? L["errors.generic"], Severity.Error);
                }
            }
            else
            {
                var result = await ApiClient.GetAsync<List<ProductDto>>("api/v1/products");
                if (result.IsSuccess && result.Data != null)
                {
                    _products = result.Data;
                    _totalPages = 1;
                }
                else
                {
                    Snackbar.Add(result.ErrorMessage ?? L["errors.generic"], Severity.Error);
                }
            }
        }
        catch (Exception)
        {
            Snackbar.Add(L["errors.generic"], Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadProductsAsync();
    }

    private async Task OnSearchChanged(string value)
    {
        _searchText = value;
        _currentPage = 1;
        await LoadProductsAsync();
    }

    private async Task OnStatusFilterChanged(string value)
    {
        _statusFilter = value;
        _currentPage = 1;
        await LoadProductsAsync();
    }

    private async Task OnGroupByChanged(string value)
    {
        _groupBy = value;
        _currentPage = 1;
        await LoadProductsAsync();
    }

    private void NavigateToNewProduct()
    {
        Navigation.NavigateTo("/products/new");
    }

    private void OnRowClick(DataGridRowClickEventArgs<ProductDto> args)
    {
        Navigation.NavigateTo($"/products/{args.Item.Id}");
    }

    private void NavigateToProduct(Guid productId)
    {
        Navigation.NavigateTo($"/products/{productId}");
    }

    private async Task HandleBarcodeAdded(ProductDto product, ProductBarcodeDto barcode)
    {
        try
        {
            var result = await ApiClient.PostAsync<ProductBarcodeDto, ProductBarcodeDto>(
                $"api/v1/products/{product.Id}/barcodes?barcode={Uri.EscapeDataString(barcode.Barcode)}&note={Uri.EscapeDataString(barcode.Note ?? "")}",
                barcode);

            if (result.IsSuccess && result.Data != null)
            {
                product.Barcodes.Add(result.Data);
                Snackbar.Add(L["products.barcodeAdded"], Severity.Success);
                StateHasChanged();
            }
            else
            {
                Snackbar.Add(result.ErrorMessage ?? L["errors.generic"], Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add(L["errors.generic"], Severity.Error);
        }
    }

    private async Task HandleBarcodeDeleted(ProductDto product, ProductBarcodeDto barcode)
    {
        var confirmed = await DialogService.ShowMessageBox(
            L["confirmations.deleteTitle"],
            L["products.confirmDeleteBarcode"],
            yesText: L["common.delete"],
            cancelText: L["common.cancel"]);

        if (confirmed != true) return;

        try
        {
            var result = await ApiClient.DeleteAsync($"api/v1/products/{product.Id}/barcodes/{barcode.Id}");

            if (result.IsSuccess)
            {
                product.Barcodes.Remove(barcode);
                Snackbar.Add(L["products.barcodeDeleted"], Severity.Success);
                StateHasChanged();
            }
            else
            {
                Snackbar.Add(result.ErrorMessage ?? L["errors.generic"], Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add(L["errors.generic"], Severity.Error);
        }
    }

    private async Task OpenAddToShoppingListDialog(ProductDto product)
    {
        var parameters = new DialogParameters<AddToShoppingListDialog>
        {
            { x => x.ProductId, product.Id },
            { x => x.ProductName, product.Name },
            { x => x.ImageUrl, GetProductImageUrl(product) }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<AddToShoppingListDialog>(L["shopping.addToList"], parameters, options);
    }

    private string? GetParentGroupImageUrl(IGrouping<string, ProductDto> group)
    {
        var parentId = group.FirstOrDefault()?.ParentProductId;
        if (parentId == null) return null;

        var parentProduct = _products.FirstOrDefault(p => p.Id == parentId.Value);
        if (parentProduct != null)
            return GetProductImageUrl(parentProduct);

        return null;
    }

    private static string? GetProductImageUrl(ProductDto product)
    {
        var primaryImage = product.Images?.FirstOrDefault(i => i.IsPrimary)
            ?? product.Images?.FirstOrDefault();

        if (primaryImage != null && !string.IsNullOrEmpty(primaryImage.ThumbnailDisplayUrl))
            return primaryImage.ThumbnailDisplayUrl;

        return product.MasterProductImageUrl;
    }
}
