@page "/products"
@attribute [Authorize]
@inject IApiClient ApiClient
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILocalizer L
@using Famick.HomeManagement.UI.Components.Products
@using Famick.HomeManagement.UI.Components.Products.ProductOnboarding
@using Famick.HomeManagement.UI.Components.Shopping
@using Famick.HomeManagement.Core.DTOs.Common
@using Famick.HomeManagement.Core.DTOs.Products
@using Famick.HomeManagement.Core.DTOs.ProductOnboarding

<MudText Typo="Typo.h4" Class="mb-4">@L["products.title"]</MudText>

@if (_isCheckingOnboarding)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_showOnboarding)
{
    <ProductOnboardingWizard OnComplete="OnOnboardingComplete" PrePopulatedAnswers="_savedAnswers" />
}
else
{
<MudPaper Elevation="1" Class="pa-4">
    @* Desktop toolbar *@
    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-4">
            <MudTextField @bind-Value="_searchText"
                          Placeholder="@L["products.searchProducts"]"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          DebounceInterval="300"
                          OnDebounceIntervalElapsed="OnSearchChanged"
                          Style="max-width: 300px;" />

            <MudSelect T="string" Value="_statusFilter"
                       ValueChanged="OnStatusFilterChanged"
                       Label="@L["products.filterByStatus"]"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="max-width: 180px;">
                <MudSelectItem Value="@("all")">@L["products.allProducts"]</MudSelectItem>
                <MudSelectItem Value="@("active")">@L["products.activeOnly"]</MudSelectItem>
                <MudSelectItem Value="@("inactive")">@L["products.inactiveOnly"]</MudSelectItem>
            </MudSelect>

            <MudSelect T="string" Value="_groupBy"
                       ValueChanged="OnGroupByChanged"
                       Label="@L["products.groupBy"]"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="max-width: 180px;">
                <MudSelectItem Value="@("none")">@L["products.groupByNone"]</MudSelectItem>
                <MudSelectItem Value="@("parentProduct")">@L["products.parentProduct"]</MudSelectItem>
                <MudSelectItem Value="@("productGroup")">@L["products.groupByProductGroup"]</MudSelectItem>
            </MudSelect>

            <MudSpacer />

            <MudTooltip Text="@(CanEdit ? null : L["common.viewerNoPermission"])" Disabled="@CanEdit">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="NavigateToNewProduct"
                           Disabled="@(!CanEdit)">
                    @L["products.addProduct"]
                </MudButton>
            </MudTooltip>
        </MudStack>
    </MudHidden>

    @* Mobile toolbar *@
    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <MudStack Spacing="2" Class="mb-3">
            <MudStack Row="true" Spacing="2">
                <MudTextField @bind-Value="_searchText"
                              Placeholder="@L["products.searchProducts"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              DebounceInterval="300"
                              OnDebounceIntervalElapsed="OnSearchChanged"
                              FullWidth="true" />
                <MudTooltip Text="@(CanEdit ? null : L["common.viewerNoPermission"])" Disabled="@CanEdit">
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   OnClick="NavigateToNewProduct"
                                   Disabled="@(!CanEdit)" />
                </MudTooltip>
            </MudStack>
            <MudStack Row="true" Spacing="2">
                <MudSelect T="string" Value="_statusFilter"
                           ValueChanged="OnStatusFilterChanged"
                           Label="@L["products.filterByStatus"]"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           FullWidth="true">
                    <MudSelectItem Value="@("all")">@L["products.allProducts"]</MudSelectItem>
                    <MudSelectItem Value="@("active")">@L["products.activeOnly"]</MudSelectItem>
                    <MudSelectItem Value="@("inactive")">@L["products.inactiveOnly"]</MudSelectItem>
                </MudSelect>

                <MudSelect T="string" Value="_groupBy"
                           ValueChanged="OnGroupByChanged"
                           Label="@L["products.groupBy"]"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           FullWidth="true">
                    <MudSelectItem Value="@("none")">@L["products.groupByNone"]</MudSelectItem>
                    <MudSelectItem Value="@("parentProduct")">@L["products.parentProduct"]</MudSelectItem>
                    <MudSelectItem Value="@("productGroup")">@L["products.groupByProductGroup"]</MudSelectItem>
                </MudSelect>
            </MudStack>
        </MudStack>
    </MudHidden>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_products.Count == 0)
    {
        <MudAlert Severity="Severity.Info">@L["products.noProducts"]</MudAlert>
    }
    else
    {
        @* Desktop: Full DataGrid *@
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            @if (_groupBy == "parentProduct" || _groupBy == "productGroup")
            {
                var groupedData = _groupBy == "parentProduct" ? _groupedProducts : _groupedByProductGroup;
                <MudExpansionPanels MultiExpansion="true">
                    @foreach (var group in groupedData)
                    {
                        <MudExpansionPanel IsInitiallyExpanded="false" Class="mb-2">
                            <TitleContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-grow-1">
                                    @{
                                        var parentImageUrl = _groupBy == "parentProduct"
                                            ? GetParentGroupImageUrl(group)
                                            : null;
                                    }
                                    @if (!string.IsNullOrEmpty(parentImageUrl))
                                    {
                                        <MudImage Src="@parentImageUrl"
                                                  Width="32" Height="32"
                                                  ObjectFit="ObjectFit.Contain"
                                                  Class="rounded"
                                                  Alt="@group.Key" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@(_groupBy == "productGroup" ? Icons.Material.Filled.Inventory : Icons.Material.Filled.Category)" Size="Size.Small" Color="Color.Primary" />
                                    }
                                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                        @(string.IsNullOrEmpty(group.Key) ? L["products.ungrouped"] : group.Key)
                                    </MudText>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text">
                                        @group.Count() @(group.Count() == 1 ? "product" : "products")
                                    </MudChip>
                                    <MudSpacer />
                                    @if (_groupBy == "parentProduct" && !string.IsNullOrEmpty(group.Key) && group.FirstOrDefault()?.ParentProductId.HasValue == true)
                                    {
                                        <span @onclick:stopPropagation="true">
                                            <MudTooltip Text="@L["products.editParent"]">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Size="Size.Small"
                                                               Color="Color.Primary"
                                                               OnClick="@(() => NavigateToProduct(group.First().ParentProductId!.Value))" />
                                            </MudTooltip>
                                        </span>
                                    }
                                </MudStack>
                            </TitleContent>
                            <ChildContent>
                                <MudDataGrid T="ProductDto"
                                     Items="@group"
                                     SortMode="SortMode.Single"
                                     Filterable="false"
                                     Hideable="false"
                                     RowClick="OnRowClick"
                                     Dense="true"
                                     Hover="true"
                                     Class="cursor-pointer">
                            <Columns>
                                <HierarchyColumn T="ProductDto" />
                                <TemplateColumn Title="" Sortable="false" Filterable="false" Style="width: 50px;">
                                    <CellTemplate>
                                        @{
                                            var imageUrl = GetProductImageUrl(context.Item);
                                        }
                                        @if (!string.IsNullOrEmpty(imageUrl))
                                        {
                                            <MudImage Src="@imageUrl"
                                                      Width="40" Height="40"
                                                      ObjectFit="ObjectFit.Cover"
                                                      Class="rounded"
                                                      Alt="@context.Item.Name" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                                                     Size="Size.Medium"
                                                     Color="Color.Default"
                                                     Style="opacity: 0.3;" />
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="x => x.Name" Title="@L["products.name"]" />
                                <TemplateColumn Title="@L["stock.inStock"]" Sortable="true" SortBy="@(new Func<ProductDto, object>(x => x.TotalStockAmount))">
                                    <CellTemplate>
                                        @if (context.Item.TotalStockAmount > 0)
                                        {
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2">
                                                    @context.Item.TotalStockAmount.ToString("0.##") @context.Item.QuantityUnitStockName
                                                </MudText>
                                                @if (context.Item.StockByLocation.Count > 1)
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        @string.Join(", ", context.Item.StockByLocation.Select(s => $"{s.LocationName}: {s.Amount:0.##}"))
                                                    </MudText>
                                                }
                                                else if (context.Item.StockByLocation.Count == 1)
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        @context.Item.StockByLocation[0].LocationName
                                                    </MudText>
                                                }
                                            </MudStack>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.body2" Color="Color.Warning">@L["stock.outOfStock"]</MudText>
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="x => x.MinStockAmount" Title="@L["products.minStock"]" />
                                <TemplateColumn Title="@L["products.status"]">
                                    <CellTemplate>
                                        @if (context.Item.IsBelowMinStock && context.Item.MinStockAmount > 0)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">@L["stock.belowMinStock"]</MudChip>
                                        }
                                        else if (context.Item.IsActive)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">@L["products.active"]</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@L["products.inactive"]</MudChip>
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="" Sortable="false" Style="width: 60px;">
                                    <CellTemplate>
                                        <span @onclick:stopPropagation="true">
                                            <MudTooltip Text="@L["shopping.addToList"]">
                                                <MudIconButton Icon="@Icons.Material.Filled.AddShoppingCart"
                                                               Size="Size.Small"
                                                               Color="Color.Primary"
                                                               OnClick="@(() => OpenAddToShoppingListDialog(context.Item))" />
                                            </MudTooltip>
                                        </span>
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                            <ChildRowContent>
                                <MudCard Elevation="0" Class="pa-4 ma-2" Style="background-color: var(--mud-palette-background-grey);">
                                    <MudCardContent>
                                        <MudText Typo="Typo.subtitle2" Class="mb-2">@L["products.barcodes"]</MudText>
                                        <ProductBarcodeList ProductId="@context.Item.Id"
                                                            Barcodes="@context.Item.Barcodes"
                                                            OnBarcodeAdded="@(barcode => HandleBarcodeAdded(context.Item, barcode))"
                                                            OnBarcodeDeleted="@(barcode => HandleBarcodeDeleted(context.Item, barcode))" />
                                    </MudCardContent>
                                </MudCard>
                            </ChildRowContent>
                        </MudDataGrid>
                            </ChildContent>
                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>
                @if (_groupBy == "parentProduct" && _standaloneProducts.Any())
                {
                    <MudDataGrid T="ProductDto"
                                 Items="@_standaloneProducts"
                                 SortMode="SortMode.Single"
                                 Filterable="false"
                                 Hideable="false"
                                 RowClick="OnRowClick"
                                 Dense="true"
                                 Hover="true"
                                 Class="cursor-pointer mt-4">
                        <Columns>
                            <HierarchyColumn T="ProductDto" />
                            <TemplateColumn Title="" Sortable="false" Filterable="false" Style="width: 50px;">
                                <CellTemplate>
                                    @{
                                        var imageUrl = GetProductImageUrl(context.Item);
                                    }
                                    @if (!string.IsNullOrEmpty(imageUrl))
                                    {
                                        <MudImage Src="@imageUrl"
                                                  Width="40" Height="40"
                                                  ObjectFit="ObjectFit.Cover"
                                                  Class="rounded"
                                                  Alt="@context.Item.Name" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                                                 Size="Size.Medium"
                                                 Color="Color.Default"
                                                 Style="opacity: 0.3;" />
                                    }
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="x => x.Name" Title="@L["products.name"]" />
                            <TemplateColumn Title="@L["stock.inStock"]" Sortable="true" SortBy="@(new Func<ProductDto, object>(x => x.TotalStockAmount))">
                                <CellTemplate>
                                    @if (context.Item.TotalStockAmount > 0)
                                    {
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2">
                                                @context.Item.TotalStockAmount.ToString("0.##") @context.Item.QuantityUnitStockName
                                            </MudText>
                                            @if (context.Item.StockByLocation.Count > 1)
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @string.Join(", ", context.Item.StockByLocation.Select(s => $"{s.LocationName}: {s.Amount:0.##}"))
                                                </MudText>
                                            }
                                            else if (context.Item.StockByLocation.Count == 1)
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @context.Item.StockByLocation[0].LocationName
                                                </MudText>
                                            }
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Warning">@L["stock.outOfStock"]</MudText>
                                    }
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="x => x.MinStockAmount" Title="@L["products.minStock"]" />
                            <TemplateColumn Title="@L["products.status"]">
                                <CellTemplate>
                                    @if (context.Item.IsBelowMinStock && context.Item.MinStockAmount > 0)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">@L["stock.belowMinStock"]</MudChip>
                                    }
                                    else if (context.Item.IsActive)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">@L["products.active"]</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@L["products.inactive"]</MudChip>
                                    }
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="" Sortable="false" Style="width: 60px;">
                                <CellTemplate>
                                    <span @onclick:stopPropagation="true">
                                        <MudTooltip Text="@L["shopping.addToList"]">
                                            <MudIconButton Icon="@Icons.Material.Filled.AddShoppingCart"
                                                           Size="Size.Small"
                                                           Color="Color.Primary"
                                                           OnClick="@(() => OpenAddToShoppingListDialog(context.Item))" />
                                        </MudTooltip>
                                    </span>
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                        <ChildRowContent>
                            <MudCard Elevation="0" Class="pa-4 ma-2" Style="background-color: var(--mud-palette-background-grey);">
                                <MudCardContent>
                                    <MudText Typo="Typo.subtitle2" Class="mb-2">@L["products.barcodes"]</MudText>
                                    <ProductBarcodeList ProductId="@context.Item.Id"
                                                        Barcodes="@context.Item.Barcodes"
                                                        OnBarcodeAdded="@(barcode => HandleBarcodeAdded(context.Item, barcode))"
                                                        OnBarcodeDeleted="@(barcode => HandleBarcodeDeleted(context.Item, barcode))" />
                                </MudCardContent>
                            </MudCard>
                        </ChildRowContent>
                    </MudDataGrid>
                }
            }
            else
            {
                <MudDataGrid T="ProductDto"
                             Items="@_filteredProducts"
                             SortMode="SortMode.Single"
                             Filterable="false"
                             Hideable="false"
                             RowClick="OnRowClick"
                             Dense="true"
                             Hover="true"
                             Class="cursor-pointer">
                    <Columns>
                        <HierarchyColumn T="ProductDto" />
                        <TemplateColumn Title="" Sortable="false" Filterable="false" Style="width: 50px;">
                            <CellTemplate>
                                @{
                                    var imageUrl = GetProductImageUrl(context.Item);
                                }
                                @if (!string.IsNullOrEmpty(imageUrl))
                                {
                                    <MudImage Src="@imageUrl"
                                              Width="40" Height="40"
                                              ObjectFit="ObjectFit.Cover"
                                              Class="rounded"
                                              Alt="@context.Item.Name" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                                             Size="Size.Medium"
                                             Color="Color.Default"
                                             Style="opacity: 0.3;" />
                                }
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="x => x.Name" Title="@L["products.name"]" />
                        <TemplateColumn Title="@L["stock.inStock"]" Sortable="true" SortBy="@(new Func<ProductDto, object>(x => x.TotalStockAmount))">
                            <CellTemplate>
                                @if (context.Item.TotalStockAmount > 0)
                                {
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2">
                                            @context.Item.TotalStockAmount.ToString("0.##") @context.Item.QuantityUnitStockName
                                        </MudText>
                                        @if (context.Item.StockByLocation.Count > 1)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @string.Join(", ", context.Item.StockByLocation.Select(s => $"{s.LocationName}: {s.Amount:0.##}"))
                                            </MudText>
                                        }
                                        else if (context.Item.StockByLocation.Count == 1)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @context.Item.StockByLocation[0].LocationName
                                            </MudText>
                                        }
                                    </MudStack>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Warning">@L["stock.outOfStock"]</MudText>
                                }
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="x => x.MinStockAmount" Title="@L["products.minStock"]" />
                        <TemplateColumn Title="@L["products.status"]">
                            <CellTemplate>
                                @if (context.Item.IsBelowMinStock && context.Item.MinStockAmount > 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">@L["stock.belowMinStock"]</MudChip>
                                }
                                else if (context.Item.IsActive)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">@L["products.active"]</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@L["products.inactive"]</MudChip>
                                }
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="" Sortable="false" Style="width: 60px;">
                            <CellTemplate>
                                <span @onclick:stopPropagation="true">
                                    <MudTooltip Text="@L["shopping.addToList"]">
                                        <MudIconButton Icon="@Icons.Material.Filled.AddShoppingCart"
                                                       Size="Size.Small"
                                                       Color="Color.Primary"
                                                       OnClick="@(() => OpenAddToShoppingListDialog(context.Item))" />
                                    </MudTooltip>
                                </span>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <ChildRowContent>
                        <MudCard Elevation="0" Class="pa-4 ma-2" Style="background-color: var(--mud-palette-background-grey);">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="mb-2">@L["products.barcodes"]</MudText>
                                <ProductBarcodeList ProductId="@context.Item.Id"
                                                    Barcodes="@context.Item.Barcodes"
                                                    OnBarcodeAdded="@(barcode => HandleBarcodeAdded(context.Item, barcode))"
                                                    OnBarcodeDeleted="@(barcode => HandleBarcodeDeleted(context.Item, barcode))" />
                            </MudCardContent>
                        </MudCard>
                    </ChildRowContent>
                </MudDataGrid>

                @if (_totalPages > 1)
                {
                    <div class="d-flex justify-center align-center pa-4">
                        <MudPagination Count="_totalPages"
                                       Selected="_currentPage"
                                       SelectedChanged="OnPageChanged"
                                       Color="Color.Primary"
                                       BoundaryCount="1"
                                       MiddleCount="3" />
                    </div>
                }
            }
        </MudHidden>

        @* Mobile: Compact list view *@
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            @if (_groupBy == "parentProduct" || _groupBy == "productGroup")
            {
                var mobileGroupedData = _groupBy == "parentProduct" ? _groupedProducts : _groupedByProductGroup;
                <MudExpansionPanels MultiExpansion="true">
                    @foreach (var group in mobileGroupedData)
                    {
                        <MudExpansionPanel IsInitiallyExpanded="false" Class="mb-2">
                            <TitleContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-grow-1">
                                    @{
                                        var mobileParentImageUrl = _groupBy == "parentProduct"
                                            ? GetParentGroupImageUrl(group)
                                            : null;
                                    }
                                    @if (!string.IsNullOrEmpty(mobileParentImageUrl))
                                    {
                                        <MudImage Src="@mobileParentImageUrl"
                                                  Width="28" Height="28"
                                                  ObjectFit="ObjectFit.Contain"
                                                  Class="rounded"
                                                  Alt="@group.Key" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@(_groupBy == "productGroup" ? Icons.Material.Filled.Inventory : Icons.Material.Filled.Category)" Size="Size.Small" Color="Color.Primary" />
                                    }
                                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">
                                        @(string.IsNullOrEmpty(group.Key) ? L["products.ungrouped"] : group.Key)
                                    </MudText>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text">
                                        @group.Count()
                                    </MudChip>
                                    <MudSpacer />
                                    @if (_groupBy == "parentProduct" && !string.IsNullOrEmpty(group.Key) && group.FirstOrDefault()?.ParentProductId.HasValue == true)
                                    {
                                        <span @onclick:stopPropagation="true">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                           Size="Size.Small"
                                                           Color="Color.Primary"
                                                           OnClick="@(() => NavigateToProduct(group.First().ParentProductId!.Value))" />
                                        </span>
                                    }
                                </MudStack>
                            </TitleContent>
                            <ChildContent>
                                <MudList T="ProductDto" Dense="true" Class="pa-0">
                                    @foreach (var product in group)
                            {
                                var imgUrl = GetProductImageUrl(product);
                                <MudListItem T="ProductDto" OnClick="@(() => NavigateToProduct(product.Id))" Class="pa-2 rounded mb-1" Style="background: var(--mud-palette-surface);">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                        @if (!string.IsNullOrEmpty(imgUrl))
                                        {
                                            <MudImage Src="@imgUrl"
                                                      Width="48" Height="48"
                                                      ObjectFit="ObjectFit.Cover"
                                                      Class="rounded"
                                                      Alt="@product.Name" />
                                        }
                                        else
                                        {
                                            <MudPaper Width="48px" Height="48px" Elevation="0" Class="d-flex align-center justify-center rounded" Style="background: var(--mud-palette-background-grey);">
                                                <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                                                         Size="Size.Medium"
                                                         Color="Color.Default"
                                                         Style="opacity: 0.4;" />
                                            </MudPaper>
                                        }
                                        <MudStack Spacing="0" Class="flex-grow-1 overflow-hidden">
