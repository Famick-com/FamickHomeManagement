@page "/meals"
@attribute [Authorize]
@inject IApiClient ApiClient
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILocalizer L
@using Famick.HomeManagement.Core.DTOs.MealPlanner

<MudText Typo="Typo.h4" Class="mb-4">@L["mealPlanner.meals.title"]</MudText>

<MudPaper Elevation="1" Class="pa-4">
    @* Desktop toolbar *@
    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-4">
            <MudTextField @bind-Value="_searchText"
                          Placeholder="@L["common.search"]"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          DebounceInterval="300"
                          OnDebounceIntervalElapsed="OnSearchChanged"
                          Style="max-width: 300px;" />

            <MudToggleIconButton @bind-Toggled="_favoritesOnly"
                                 Icon="@Icons.Material.Outlined.FavoriteBorder"
                                 ToggledIcon="@Icons.Material.Filled.Favorite"
                                 ToggledColor="Color.Error"
                                 Title="@L["mealPlanner.meals.filter.favorites"]"
                                 ToggledTitle="@L["mealPlanner.meals.filter.all"]" />

            <MudSpacer />

            <MudTooltip Text="@(CanEdit ? null : L["common.viewerNoPermission"])" Disabled="@CanEdit">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenCreateDialog"
                           Disabled="@(!CanEdit)">
                    @L["mealPlanner.meals.add"]
                </MudButton>
            </MudTooltip>
        </MudStack>
    </MudHidden>

    @* Mobile toolbar *@
    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <MudStack Spacing="2" Class="mb-3">
            <MudStack Row="true" Spacing="2">
                <MudTextField @bind-Value="_searchText"
                              Placeholder="@L["common.search"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              DebounceInterval="300"
                              OnDebounceIntervalElapsed="OnSearchChanged"
                              FullWidth="true" />
                <MudToggleIconButton @bind-Toggled="_favoritesOnly"
                                     Icon="@Icons.Material.Outlined.FavoriteBorder"
                                     ToggledIcon="@Icons.Material.Filled.Favorite"
                                     ToggledColor="Color.Error" />
                <MudTooltip Text="@(CanEdit ? null : L["common.viewerNoPermission"])" Disabled="@CanEdit">
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   OnClick="OpenCreateDialog"
                                   Disabled="@(!CanEdit)" />
                </MudTooltip>
            </MudStack>
        </MudStack>
    </MudHidden>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (!_meals.Any())
    {
        <MudAlert Severity="Severity.Info">@L["mealPlanner.meals.noMeals"]</MudAlert>
    }
    else
    {
        @* Desktop: Table *@
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudTable T="MealSummaryDto" Items="@_meals" Dense="true" Hover="true"
                       OnRowClick="@(args => NavigateToMeal(args.Item.Id))" Style="cursor: pointer;">
                <HeaderContent>
                    <MudTh>@L["mealPlanner.meals.name"]</MudTh>
                    <MudTh>@L["mealPlanner.meals.items"]</MudTh>
                    <MudTh></MudTh>
                    <MudTh>@L["common.updated"]</MudTh>
                    <MudTh Style="width: 90px;"></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudText>@context.Name</MudText>
                            @if (context.IsFavorite)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Favorite" Size="Size.Small" Color="Color.Error" />
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd>
                        <MudText>@context.ItemCount</MudText>
                    </MudTd>
                    <MudTd></MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@context.CreatedAt.ToString("d")</MudText>
                    </MudTd>
                    <MudTd>
                        <MudStack Row="true" Spacing="0" @onclick:stopPropagation="true">
                            <MudTooltip Text="@L["common.edit"]">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="@(() => OpenEditDialog(context.Id))"
                                               Disabled="@(!CanEdit)" />
                            </MudTooltip>
                            <MudTooltip Text="@L["common.delete"]">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteMealAsync(context))"
                                               Disabled="@(!CanEdit)" />
                            </MudTooltip>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudHidden>

        @* Mobile: Cards *@
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudStack Spacing="2">
                @foreach (var meal in _meals)
                {
                    <MudCard Elevation="1" @onclick="@(() => NavigateToMeal(meal.Id))" Style="cursor: pointer;">
                        <MudCardContent Class="pa-3">
                            <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.LunchDining" Size="Size.Large" Color="Color.Secondary" />
                                <MudStack Spacing="0" Class="flex-grow-1">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.subtitle1">@meal.Name</MudText>
                                        @if (meal.IsFavorite)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Favorite" Size="Size.Small" Color="Color.Error" />
                                        }
                                    </MudStack>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @meal.ItemCount @L["mealPlanner.meals.items"].ToLowerInvariant()
                                    </MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="0" @onclick:stopPropagation="true">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="@(() => OpenEditDialog(meal.Id))"
                                                   Disabled="@(!CanEdit)" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => DeleteMealAsync(meal))"
                                                   Disabled="@(!CanEdit)" />
                                </MudStack>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                }
            </MudStack>
        </MudHidden>
    }
</MudPaper>

<MealEditor @ref="_mealEditor" OnSaved="LoadMealsAsync" />

@code {
    [CascadingParameter(Name = "CanEdit")]
    private bool CanEdit { get; set; }

    private bool _isLoading = true;
    private string _searchText = string.Empty;
    private bool _favoritesOnly;
    private List<MealSummaryDto> _meals = new();
    private MealEditor? _mealEditor;

    protected override async Task OnInitializedAsync()
    {
        await LoadMealsAsync();
    }

    private async Task LoadMealsAsync()
    {
        _isLoading = true;
        try
        {
            var queryParams = new List<string>();
            if (!string.IsNullOrWhiteSpace(_searchText))
                queryParams.Add($"searchTerm={Uri.EscapeDataString(_searchText)}");
            if (_favoritesOnly)
                queryParams.Add("favoritesOnly=true");

            var queryString = string.Join("&", queryParams);
            var endpoint = string.IsNullOrEmpty(queryString) ? "api/v1/meals" : $"api/v1/meals?{queryString}";
            var result = await ApiClient.GetAsync<List<MealSummaryDto>>(endpoint);

            if (result.IsSuccess && result.Data != null)
            {
                _meals = result.Data;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading meals: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnSearchChanged(string value)
    {
        _searchText = value;
        await LoadMealsAsync();
    }

    private void NavigateToMeal(Guid id)
    {
        Navigation.NavigateTo($"/meals/{id}");
    }

    private async Task OpenCreateDialog()
    {
        if (_mealEditor != null)
            await _mealEditor.OpenCreateAsync();
    }

    private async Task OpenEditDialog(Guid id)
    {
        if (_mealEditor != null)
            await _mealEditor.OpenEditAsync(id);
    }

    private async Task DeleteMealAsync(MealSummaryDto meal)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            L["confirmations.deleteTitle"],
            L["mealPlanner.meals.confirmDelete"],
            yesText: L["common.delete"],
            cancelText: L["common.cancel"]);

        if (confirmed != true) return;

        var result = await ApiClient.DeleteAsync($"api/v1/meals/{meal.Id}");
        if (result.IsSuccess)
        {
            Snackbar.Add(L["mealPlanner.meals.deleted"], Severity.Success);
            await LoadMealsAsync();
        }
        else
        {
            Snackbar.Add(result.ErrorMessage ?? L["common.error"], Severity.Error);
        }
    }
}
