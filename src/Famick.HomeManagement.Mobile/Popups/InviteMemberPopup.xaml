<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:models="clr-namespace:Famick.HomeManagement.Mobile.Models"
               x:Class="Famick.HomeManagement.Mobile.Popups.InviteMemberPopup"
               x:TypeArguments="models:InviteMemberResult"
               CanBeDismissedByTappingOutsideOfPopup="True">

    <Border StrokeShape="RoundRectangle 16"
            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
            Padding="24"
            WidthRequest="320">
        <VerticalStackLayout Spacing="16">
            <!-- Title -->
            <Label x:Name="TitleLabel"
                   Text="Invite Member"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <!-- Email -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Email"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#616161, Dark=#BDBDBD}" />
                <Entry x:Name="EmailEntry"
                       Placeholder="email@example.com"
                       Keyboard="Email"
                       IsTextPredictionEnabled="False" />
            </VerticalStackLayout>

            <!-- Phone -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Phone Number"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#616161, Dark=#BDBDBD}" />
                <Entry x:Name="PhoneEntry"
                       Placeholder="(555) 123-4567"
                       Keyboard="Telephone"
                       IsTextPredictionEnabled="False" />
            </VerticalStackLayout>

            <!-- Error -->
            <Label x:Name="ErrorLabel"
                   TextColor="Red"
                   FontSize="13"
                   IsVisible="False"
                   HorizontalTextAlignment="Center" />

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="Cancel"
                        Clicked="OnCancelClicked"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                        BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                        BorderWidth="1"
                        CornerRadius="8" />
                <Button Grid.Column="1"
                        Text="Send Invite"
                        Clicked="OnSendInviteClicked"
                        BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}"
                        TextColor="White"
                        CornerRadius="8" />
            </Grid>
        </VerticalStackLayout>
    </Border>

</toolkit:Popup>
