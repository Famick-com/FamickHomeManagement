<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:popups="clr-namespace:Famick.HomeManagement.Mobile.Popups"
               x:Class="Famick.HomeManagement.Mobile.Popups.EquipmentUsageLogPopup"
               x:TypeArguments="popups:EquipmentUsageLogPopupResult"
               Padding="10">

    <Border Padding="24" StrokeShape="RoundRectangle 16" Stroke="Transparent" StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}" WidthRequest="340">
        <VerticalStackLayout Spacing="14">
            <Label x:Name="TitleLabel" Text="Add Usage Reading" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" />

            <VerticalStackLayout Spacing="4">
                <Label Text="Date" FontSize="13" TextColor="Gray" />
                <DatePicker x:Name="DatePicker"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#3A3A3A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4">
                <Label x:Name="ReadingLabel" Text="Reading *" FontSize="13" TextColor="Gray" />
                <Entry x:Name="ReadingEntry" Placeholder="e.g. 15000" Keyboard="Numeric"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#3A3A3A}"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4">
                <Label Text="Notes" FontSize="13" TextColor="Gray" />
                <Editor x:Name="NotesEditor" Placeholder="Optional notes..."
                        HeightRequest="60" AutoSize="TextChanges"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#3A3A3A}"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0" Text="Cancel" Clicked="OnCancelClicked"
                        BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        CornerRadius="20" HeightRequest="44" />
                <Button Grid.Column="1" Text="Add" Clicked="OnSaveClicked"
                        BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}"
                        TextColor="White" CornerRadius="20" HeightRequest="44" />
            </Grid>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
