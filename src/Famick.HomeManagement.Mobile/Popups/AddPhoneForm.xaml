<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sfInputs="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
             xmlns:controls="clr-namespace:Famick.HomeManagement.Mobile.Controls"
             x:Class="Famick.HomeManagement.Mobile.Popups.AddPhoneForm">
    <VerticalStackLayout Spacing="12" Padding="20"
                         BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
        <Label Text="Add Phone Number" FontSize="18" FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="{AppThemeBinding Light=Black, Dark=White}" />

        <VerticalStackLayout Spacing="4">
            <Label Text="Type" FontSize="13"
                   TextColor="{AppThemeBinding Light=#666, Dark=#AAA}" />
            <sfInputs:SfComboBox x:Name="TypeCombo"
                                 DisplayMemberPath="Label"
                                 TextMemberPath="Label"
                                 IsEditable="False"
                                 IsClearButtonVisible="False" />
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="4">
            <Label Text="Phone Number" FontSize="13"
                   TextColor="{AppThemeBinding Light=#666, Dark=#AAA}" />
            <controls:PhoneNumberEditor x:Name="PhoneEditor" />
        </VerticalStackLayout>

        <Grid ColumnDefinitions="*,Auto">
            <Label Text="Set as primary" VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            <Switch x:Name="PrimarySwitch" Grid.Column="1" />
        </Grid>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,8,0,0">
            <Button Grid.Column="0" x:Name="CancelButton" Text="Cancel"
                    BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    CornerRadius="20" HeightRequest="44"
                    Clicked="OnCancelClicked" />
            <Button Grid.Column="1" x:Name="AddButton" Text="Add"
                    BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}"
                    TextColor="White" CornerRadius="20" HeightRequest="44"
                    Clicked="OnAddClicked" />
        </Grid>
    </VerticalStackLayout>
</ContentView>
