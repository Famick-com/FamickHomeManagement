<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:models="clr-namespace:Famick.HomeManagement.Mobile.Models"
               x:Class="Famick.HomeManagement.Mobile.Popups.LocationPopup"
               x:TypeArguments="models:LocationPopupResult"
               Padding="10">

    <Border Padding="24" StrokeShape="RoundRectangle 16" Stroke="Transparent" StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}" WidthRequest="340">
        <ScrollView MaximumHeightRequest="500">
            <VerticalStackLayout Spacing="14">
                <Label x:Name="TitleLabel" Text="Add Location" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="Name *" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="NameEntry" Placeholder="e.g. Kitchen, Pantry, Freezer"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#3A3A3A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Description" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="DescriptionEntry" Placeholder="Optional description"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#3A3A3A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Sort Order" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="SortOrderEntry" Text="0" Keyboard="Numeric"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#3A3A3A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                    <Label Grid.Column="0" Text="Active" FontSize="15" VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Switch x:Name="ActiveSwitch" Grid.Column="1" IsToggled="True" />
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Grid.Column="0" Text="Cancel" Clicked="OnCancelClicked"
                            BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            CornerRadius="20" HeightRequest="44" />
                    <Button Grid.Column="1" x:Name="SaveButton" Text="Add" Clicked="OnSaveClicked"
                            BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}"
                            TextColor="White" CornerRadius="20" HeightRequest="44" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>
