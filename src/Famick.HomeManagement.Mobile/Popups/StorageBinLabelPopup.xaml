<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:popups="clr-namespace:Famick.HomeManagement.Mobile.Popups"
               x:Class="Famick.HomeManagement.Mobile.Popups.StorageBinLabelPopup"
               x:TypeArguments="models:StorageBinLabelPopupResult"
               xmlns:models="clr-namespace:Famick.HomeManagement.Mobile.Models"
               Padding="10">

    <Border Padding="24" StrokeShape="RoundRectangle 16" Stroke="Transparent" StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}" WidthRequest="340">
        <VerticalStackLayout Spacing="14">
            <Label Text="Print Labels" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" />

            <VerticalStackLayout Spacing="4">
                <Label Text="Label Format" FontSize="13" TextColor="Gray" />
                <Picker x:Name="FormatPicker"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#3A3A3A}"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Avery 94104 (2x2, 9/sheet)</x:String>
                            <x:String>Avery 94256 (4x5, 4/sheet)</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4">
                <Label Text="Sheet Count (1-10)" FontSize="13" TextColor="Gray" />
                <Entry x:Name="SheetCountEntry" Text="1" Keyboard="Numeric"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#3A3A3A}"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            </VerticalStackLayout>

            <Grid x:Name="RepeatSection" ColumnDefinitions="*,Auto" Padding="0,2" IsVisible="False">
                <Label Text="Repeat to fill sheet" FontSize="13" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                <Switch x:Name="RepeatSwitch" Grid.Column="1"
                        OnColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />
            </Grid>

            <Label x:Name="InfoLabel" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0" Text="Cancel" Clicked="OnCancelClicked"
                        BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        CornerRadius="20" HeightRequest="44" />
                <Button Grid.Column="1" Text="Print" Clicked="OnPrintClicked"
                        BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}"
                        TextColor="White" CornerRadius="20" HeightRequest="44" />
            </Grid>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
