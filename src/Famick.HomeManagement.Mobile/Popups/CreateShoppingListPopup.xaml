<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:models="clr-namespace:Famick.HomeManagement.Mobile.Models"
               x:Class="Famick.HomeManagement.Mobile.Popups.CreateShoppingListPopup"
               x:TypeArguments="models:CreateShoppingListResult"
               Padding="10">

    <Border Padding="24" StrokeShape="RoundRectangle 16" Stroke="Transparent" StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}" WidthRequest="340">
        <ScrollView MaximumHeightRequest="550">
            <VerticalStackLayout Spacing="14">
                <Label Text="New Shopping List" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="Name *" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="NameEntry" Placeholder="e.g. Weekly Groceries"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#3A3A3A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Notes" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="DescriptionEntry" Placeholder="Optional notes"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#3A3A3A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Store *" FontSize="13" TextColor="Gray" />
                    <Picker x:Name="StorePicker"
                            Title="Select a store"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            TitleColor="Gray"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#3A3A3A}" />
                </VerticalStackLayout>

                <!-- Inline New Store Section -->
                <VerticalStackLayout x:Name="NewStoreSection" IsVisible="False" Spacing="8"
                                     Padding="12" BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#333333}">
                    <Label Text="New Store" FontSize="15" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Store Name *" FontSize="13" TextColor="Gray" />
                        <Entry x:Name="NewStoreNameEntry" Placeholder="e.g. Kroger, Walmart"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#3A3A3A}"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Address" FontSize="13" TextColor="Gray" />
                        <Entry x:Name="NewStoreAddressEntry" Placeholder="Optional address"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#3A3A3A}"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </VerticalStackLayout>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Cancel" Clicked="OnCancelNewStoreClicked"
                                FontSize="13" HeightRequest="36" CornerRadius="18"
                                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Button Grid.Column="1" x:Name="SaveStoreButton" Text="Add Store" Clicked="OnSaveNewStoreClicked"
                                FontSize="13" HeightRequest="36" CornerRadius="18"
                                BackgroundColor="{AppThemeBinding Light=#43A047, Dark=#2E7D32}"
                                TextColor="White" />
                    </Grid>
                </VerticalStackLayout>

                <Button x:Name="AddStoreButton" Text="+ New Store" Clicked="OnAddNewStoreClicked"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#1976D2, Dark=#42A5F5}"
                        FontSize="14" HorizontalOptions="Start" Padding="0"
                        HeightRequest="36" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Grid.Column="0" Text="Cancel" Clicked="OnCancelClicked"
                            BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            CornerRadius="20" HeightRequest="44" />
                    <Button Grid.Column="1" Text="Create" Clicked="OnCreateClicked"
                            BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}"
                            TextColor="White" CornerRadius="20" HeightRequest="44" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>
