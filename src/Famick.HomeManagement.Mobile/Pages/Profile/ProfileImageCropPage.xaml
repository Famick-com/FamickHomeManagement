<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:imageEditor="clr-namespace:Syncfusion.Maui.ImageEditor;assembly=Syncfusion.Maui.ImageEditor"
             x:Class="Famick.HomeManagement.Mobile.Pages.Profile.ProfileImageCropPage"
             Title="Crop Photo"
             BackgroundColor="Black">

    <Grid RowDefinitions="*,Auto">
        <imageEditor:SfImageEditor x:Name="ImageEditor"
                                   Grid.Row="0"
                                   ShowToolbar="False"
                                   AllowZoom="True"
                                   ImageLoaded="OnImageLoaded" />

        <HorizontalStackLayout Grid.Row="1"
                               HorizontalOptions="Center"
                               Spacing="30"
                               Padding="20">
            <Button Text="Cancel"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="16"
                    Clicked="OnCancelClicked" />
            <Button Text="Use Photo"
                    BackgroundColor="#1976D2"
                    TextColor="White"
                    FontSize="16"
                    CornerRadius="8"
                    Padding="20,10"
                    Clicked="OnUsePhotoClicked" />
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
