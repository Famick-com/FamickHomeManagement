<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.ProductDetailPage"
             Title="Product"
             Shell.NavBarIsVisible="True">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Edit" Clicked="OnEditClicked" IconImageSource="pencil" />
    </ContentPage.ToolbarItems>

    <Grid>
        <!-- Loading -->
        <ActivityIndicator x:Name="LoadingIndicator"
                           IsRunning="True"
                           IsVisible="True"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <!-- Error -->
        <Border x:Name="ErrorFrame"
                IsVisible="False"
                Margin="20"
                Padding="20"
                StrokeShape="RoundRectangle 10"
                Stroke="Transparent"
                BackgroundColor="#FFEBEE"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="10">
                <Label x:Name="ErrorLabel"
                       TextColor="#C62828"
                       HorizontalOptions="Center" />
                <Button Text="Retry"
                        Clicked="OnRetryClicked" />
            </VerticalStackLayout>
        </Border>

        <!-- Content -->
        <ScrollView x:Name="ContentScroll" IsVisible="False">
            <VerticalStackLayout Spacing="0" Padding="15">

                <!-- Product Image -->
                <Border x:Name="ImageSection"
                        IsVisible="False"
                        HeightRequest="200"
                        Margin="0,0,0,12"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}"
                        HorizontalOptions="Center">
                    <Image x:Name="ProductImage"
                           HeightRequest="200"
                           Aspect="AspectFit" />
                </Border>

                <!-- Product Name -->
                <Label x:Name="TitleLabel"
                       FontSize="24"
                       FontAttributes="Bold"
                       Margin="0,0,0,4" />

                <!-- Status Badges -->
                <HorizontalStackLayout x:Name="BadgesRow" Spacing="8" Margin="0,0,0,12">
                    <Border x:Name="ActiveBadge"
                            Padding="8,4"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            BackgroundColor="#E8F5E9">
                        <Label Text="ACTIVE" FontSize="11" FontAttributes="Bold" TextColor="#2E7D32" />
                    </Border>
                    <Border x:Name="InactiveBadge"
                            IsVisible="False"
                            Padding="8,4"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            BackgroundColor="#EEEEEE">
                        <Label Text="INACTIVE" FontSize="11" FontAttributes="Bold" TextColor="#757575" />
                    </Border>
                    <Border x:Name="LowStockBadge"
                            IsVisible="False"
                            Padding="8,4"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            BackgroundColor="#FCE4EC">
                        <Label Text="LOW STOCK" FontSize="11" FontAttributes="Bold" TextColor="#C62828" />
                    </Border>
                </HorizontalStackLayout>

                <!-- Description -->
                <Border x:Name="DescriptionSection"
                        IsVisible="False"
                        Padding="12"
                        Margin="0,0,0,12"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Description"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="Gray" />
                        <Label x:Name="DescriptionLabel" FontSize="14"
                               TextColor="{AppThemeBinding Light=#424242, Dark=#BDBDBD}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Stock Info Card -->
                <Border Padding="12"
                        Margin="0,0,0,12"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Stock" FontSize="13" FontAttributes="Bold" TextColor="Gray" />
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="Total Stock" FontSize="14" TextColor="Gray" VerticalOptions="Center" />
                            <Label x:Name="TotalStockLabel" FontSize="14" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="Min Stock" FontSize="14" TextColor="Gray" VerticalOptions="Center" />
                            <Label x:Name="MinStockLabel" FontSize="14"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <VerticalStackLayout x:Name="StockByLocationList" Spacing="4" Margin="0,4,0,0" />
                    </VerticalStackLayout>
                </Border>

                <!-- Details Card -->
                <Border Padding="12"
                        Margin="0,0,0,12"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Details" FontSize="13" FontAttributes="Bold" TextColor="Gray" />
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="Location" FontSize="14" TextColor="Gray" VerticalOptions="Center" />
                            <Label x:Name="LocationLabel" FontSize="14"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout x:Name="ProductGroupRow" Spacing="8" IsVisible="False">
                            <Label Text="Group" FontSize="14" TextColor="Gray" VerticalOptions="Center" />
                            <Label x:Name="ProductGroupLabel" FontSize="14"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="Purchase Unit" FontSize="14" TextColor="Gray" VerticalOptions="Center" />
                            <Label x:Name="PurchaseUnitLabel" FontSize="14"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="Stock Unit" FontSize="14" TextColor="Gray" VerticalOptions="Center" />
                            <Label x:Name="StockUnitLabel" FontSize="14"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout x:Name="BestBeforeRow" Spacing="8" IsVisible="False">
                            <Label Text="Best Before Days" FontSize="14" TextColor="Gray" VerticalOptions="Center" />
                            <Label x:Name="BestBeforeDaysLabel" FontSize="14"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Parent/Child Info -->
                <Border x:Name="ParentChildSection"
                        IsVisible="False"
                        Padding="12"
                        Margin="0,0,0,12"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Product Hierarchy" FontSize="13" FontAttributes="Bold" TextColor="Gray" />
                        <HorizontalStackLayout x:Name="ParentRow" Spacing="8" IsVisible="False">
                            <Label Text="Parent" FontSize="14" TextColor="Gray" VerticalOptions="Center" />
                            <Label x:Name="ParentLabel" FontSize="14"
                                   TextColor="{AppThemeBinding Light=#1565C0, Dark=#90CAF9}"
                                   TextDecorations="Underline"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnParentProductTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout x:Name="ChildCountRow" Spacing="8" IsVisible="False">
                            <Label Text="Variants" FontSize="14" TextColor="Gray" VerticalOptions="Center" />
                            <Label x:Name="ChildCountLabel" FontSize="14"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Barcodes -->
                <Border x:Name="BarcodesSection"
                        IsVisible="False"
                        Padding="12"
                        Margin="0,0,0,20"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Barcodes" FontSize="13" FontAttributes="Bold" TextColor="Gray" />
                        <VerticalStackLayout x:Name="BarcodesList" Spacing="2" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
