<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.MealPlanner.MealSelectionPage"
             Title="Select Meal"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
        <!-- Row 0: Tab toggle (Meals / Recipes / Note) -->
        <HorizontalStackLayout Grid.Row="0" Spacing="8" Padding="10,5,10,0">
            <Button x:Name="TabMeals" Text="Meals" CornerRadius="16" Padding="14,6"
                    FontSize="13" Clicked="OnTabMealsClicked"
                    BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}" TextColor="White" />
            <Button x:Name="TabRecipes" Text="Recipes" CornerRadius="16" Padding="14,6"
                    FontSize="13" Clicked="OnTabRecipesClicked"
                    BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                    TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}" />
            <Button x:Name="TabNote" Text="Note" CornerRadius="16" Padding="14,6"
                    FontSize="13" Clicked="OnTabNoteClicked"
                    BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                    TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}" />
        </HorizontalStackLayout>

        <!-- Row 1: Search + New Meal -->
        <Grid Grid.Row="1" x:Name="SearchRow" ColumnDefinitions="*,Auto" Margin="10,5" ColumnSpacing="8">
            <Entry Grid.Column="0" x:Name="SearchEntry" Placeholder="Search meals..."
                   ReturnType="Search" TextChanged="OnSearchTextChanged"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            <Button Grid.Column="1" x:Name="NewMealButton" Text="+ New" Clicked="OnNewMealTapped"
                    FontSize="13" Padding="10,6" CornerRadius="8"
                    BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"
                    TextColor="{AppThemeBinding Light=White, Dark=Black}" />
        </Grid>

        <!-- Row 2: Quick Note (only visible on Note tab) -->
        <Border Grid.Row="2" x:Name="QuickNoteSection" IsVisible="False" Margin="10,4" Padding="12"
                StrokeShape="RoundRectangle 10" Stroke="Transparent"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
            <VerticalStackLayout Spacing="8">
                <Label Text="Quick Note" FontSize="14" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Entry Grid.Column="0" x:Name="NoteEntry"
                           Placeholder="e.g., Leftovers, Eating out..."
                           BackgroundColor="Transparent"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Button Grid.Column="1" Text="Save" Clicked="OnSaveNoteTapped"
                            FontSize="14" Padding="12,6"
                            BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"
                            TextColor="{AppThemeBinding Light=White, Dark=Black}"
                            CornerRadius="8" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- Row 3: List header -->
        <Label Grid.Row="3" x:Name="ListHeader" Text="Select a meal to add" FontSize="13" Margin="14,8,14,0"
               TextColor="{AppThemeBinding Light=#888888, Dark=#999999}" />

        <!-- Row 4: List content -->
        <ActivityIndicator x:Name="LoadingIndicator" Grid.Row="4" IsRunning="True" IsVisible="True"
                           VerticalOptions="Center" Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <!-- Meals list -->
        <CollectionView x:Name="MealsCollection" Grid.Row="4" IsVisible="False"
                        SelectionMode="Single" SelectionChanged="OnMealSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="10,4" Padding="12" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                    <Label Text="❤️" FontSize="14" IsVisible="{Binding IsFavorite}" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label FontSize="12" TextColor="{AppThemeBinding Light=#888888, Dark=#999999}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding ItemCount}" />
                                            <Span Text=" items" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="+" FontSize="22" FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Recipes list -->
        <CollectionView x:Name="RecipesCollection" Grid.Row="4" IsVisible="False"
                        SelectionMode="Single" SelectionChanged="OnRecipeSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="10,4" Padding="12" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                <HorizontalStackLayout Spacing="8">
                                    <Label FontSize="12" TextColor="{AppThemeBinding Light=#888888, Dark=#999999}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding StepCount}" />
                                                <Span Text=" steps" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label FontSize="12" TextColor="{AppThemeBinding Light=#888888, Dark=#999999}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Servings}" />
                                                <Span Text=" servings" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="+" FontSize="22" FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#43A047, Dark=#81C784}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
