<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.MealPlanner.MealDetailPage"
             Title="Meal Detail"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Grid RowDefinitions="*">
        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" IsVisible="True"
                           VerticalOptions="Center" Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <ScrollView x:Name="ContentArea" IsVisible="False">
            <VerticalStackLayout Spacing="10" Padding="15">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label x:Name="MealNameLabel" FontSize="24" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Label x:Name="MealNotesLabel" FontSize="14"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                    </VerticalStackLayout>
                    <Label x:Name="FavoriteLabel" Grid.Column="1" Text="❤️" FontSize="24"
                           VerticalOptions="Start" IsVisible="False" />
                </Grid>

                <!-- Items Section -->
                <Border Padding="15" StrokeShape="RoundRectangle 12" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.1" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Items" FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <VerticalStackLayout x:Name="ItemsList" Spacing="6" />
                    </VerticalStackLayout>
                </Border>

                <!-- Nutrition Section -->
                <Border x:Name="NutritionSection" Padding="15" StrokeShape="RoundRectangle 12" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}" IsVisible="False">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.1" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Nutrition" FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="15" RowSpacing="8">
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                                <Label Text="Calories" FontSize="12" TextColor="{AppThemeBinding Light=#888888, Dark=#999999}" />
                                <Label x:Name="CaloriesLabel" FontSize="18" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                                <Label Text="Protein" FontSize="12" TextColor="{AppThemeBinding Light=#888888, Dark=#999999}" />
                                <Label x:Name="ProteinLabel" FontSize="18" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                                <Label Text="Carbs" FontSize="12" TextColor="{AppThemeBinding Light=#888888, Dark=#999999}" />
                                <Label x:Name="CarbsLabel" FontSize="18" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                                <Label Text="Fat" FontSize="12" TextColor="{AppThemeBinding Light=#888888, Dark=#999999}" />
                                <Label x:Name="FatLabel" FontSize="18" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
