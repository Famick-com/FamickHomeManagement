<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.MealPlanner.MealEditPage"
             Title="Meal"
             Shell.NavBarIsVisible="True"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Shell.TitleView>
        <Label x:Name="TitleLabel"
               Text="New Meal"
               FontSize="18"
               FontAttributes="Bold"
               VerticalOptions="Center"
               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
    </Shell.TitleView>

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="SaveToolbarItem" Text="Save" Clicked="OnSaveClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*">
        <!-- Loading -->
        <ActivityIndicator x:Name="LoadingIndicator"
                           IsRunning="False"
                           IsVisible="False"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <!-- Content -->
        <ScrollView x:Name="ContentScroll">
            <VerticalStackLayout Padding="15" Spacing="12">

                <!-- Name -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Name *" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="NameEntry" Placeholder="Meal name"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Notes -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Notes" FontSize="13" TextColor="Gray" />
                    <Editor x:Name="NotesEditor"
                            Placeholder="Notes about this meal..."
                            HeightRequest="80"
                            AutoSize="TextChanges"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Favorite Toggle -->
                <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                    <Label Text="Favorite" FontSize="15" VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Switch x:Name="FavoriteSwitch" Grid.Column="1"
                            OnColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />
                </Grid>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />

                <!-- Items Section Header with Dropdown -->
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Label Text="Items" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Button Grid.Column="1" Text="+ Product" Clicked="OnAddProductClicked"
                            FontSize="13" HeightRequest="34" Padding="10,0"
                            BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"
                            TextColor="{AppThemeBinding Light=White, Dark=Black}"
                            CornerRadius="8" />
                    <Button Grid.Column="2" Text="+ Recipe" Clicked="OnAddRecipeClicked"
                            FontSize="13" HeightRequest="34" Padding="10,0"
                            BackgroundColor="{AppThemeBinding Light=#43A047, Dark=#81C784}"
                            TextColor="{AppThemeBinding Light=White, Dark=Black}"
                            CornerRadius="8" />
                </Grid>

                <VerticalStackLayout x:Name="ItemsList" Spacing="6" />

                <!-- Empty state -->
                <Label x:Name="EmptyItemsLabel" Text="No items yet. Tap '+ Product' or '+ Recipe' to add one."
                       FontSize="13" TextColor="{AppThemeBinding Light=#888888, Dark=#999999}"
                       HorizontalOptions="Center" Margin="0,10" />

                <!-- Bottom spacing -->
                <BoxView HeightRequest="20" BackgroundColor="Transparent" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Search Overlay (covers content when active) -->
        <Grid x:Name="SearchOverlay" IsVisible="False" InputTransparent="True"
              BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}"
              RowDefinitions="Auto,Auto,Auto,*,Auto">

            <!-- Overlay Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="15,10" ColumnSpacing="10">
                <Button Grid.Column="0" Text="Cancel" Clicked="OnSearchCancelClicked"
                        FontSize="14" Padding="8,4"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />
                <Label x:Name="SearchTitleLabel" Grid.Column="1" Text="Search Products"
                       FontSize="17" FontAttributes="Bold"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                <BoxView Grid.Column="2" WidthRequest="60" BackgroundColor="Transparent" />
            </Grid>

            <!-- Search Entry -->
            <Entry x:Name="SearchEntry" Grid.Row="1" Placeholder="Search..."
                   ReturnType="Search" TextChanged="OnSearchTextChanged" Completed="OnSearchCompleted"
                   Margin="15,0" ClearButtonVisibility="WhileEditing"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <!-- Store Search Button (product mode only) -->
            <Button x:Name="StoreSearchButton" Grid.Row="2" Text="Search Store Integrations"
                    Clicked="OnStoreSearchClicked" Margin="15,8"
                    FontSize="13" HeightRequest="36" Padding="12,0"
                    BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#3A3A3A}"
                    TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}"
                    CornerRadius="8" />

            <!-- Search Results -->
            <Grid Grid.Row="3">
                <ActivityIndicator x:Name="SearchLoadingIndicator"
                                   IsRunning="False" IsVisible="False"
                                   VerticalOptions="Center"
                                   Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

                <CollectionView x:Name="SearchResultsCollection" SelectionMode="None"
                                SelectionChanged="OnSearchResultSelected">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8" Padding="20">
                            <Label x:Name="SearchEmptyLabel" Text="Type to search..."
                                   FontSize="14" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#888888, Dark=#999999}" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>
            </Grid>

            <!-- Store Search Results Section -->
            <VerticalStackLayout x:Name="StoreResultsSection" Grid.Row="4" IsVisible="False"
                                 Margin="15,0,15,10" Spacing="6">
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />
                <Label Text="Store Results" FontSize="14" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                <CollectionView x:Name="StoreResultsCollection" SelectionMode="None"
                                SelectionChanged="OnStoreResultSelected" HeightRequest="200" />
            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>
