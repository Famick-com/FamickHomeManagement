<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.Tasks.TaskEditPage"
             Title="Task"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Grid RowDefinitions="*">
        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" IsVisible="True"
                           VerticalOptions="Center" Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <ScrollView x:Name="ContentScroll" IsVisible="False">
            <VerticalStackLayout Spacing="16" Padding="16">

                <!-- Description -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Description" FontSize="14" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}" />
                    <Editor x:Name="DescriptionEditor" Placeholder="What needs to be done?"
                            HeightRequest="100" AutoSize="TextChanges"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Task Type -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Type" FontSize="14" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}" />
                    <Picker x:Name="TaskTypePicker" Title="Select type"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Other</x:String>
                                <x:String>Inventory</x:String>
                                <x:String>Product</x:String>
                                <x:String>Equipment</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </VerticalStackLayout>

                <!-- Reason -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Reason / Notes" FontSize="14" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}" />
                    <Editor x:Name="ReasonEditor" Placeholder="Why is this needed?"
                            HeightRequest="80" AutoSize="TextChanges"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Completed info (edit mode only) -->
                <VerticalStackLayout x:Name="CompletedSection" IsVisible="False" Spacing="4">
                    <Label Text="Status" FontSize="14" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}" />
                    <HorizontalStackLayout Spacing="8">
                        <Border Padding="8,4" StrokeShape="RoundRectangle 8" Stroke="Transparent"
                                BackgroundColor="#4CAF50">
                            <Label x:Name="CompletedLabel" FontSize="12" TextColor="White" />
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Save Button -->
                <Button x:Name="SaveButton" Text="Save Task" Clicked="OnSaveClicked"
                        BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}"
                        TextColor="White" CornerRadius="8" HeightRequest="48"
                        FontSize="16" FontAttributes="Bold" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
