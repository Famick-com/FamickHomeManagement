<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Famick.HomeManagement.Mobile.Pages.Tasks.TasksListPage"
             Title="Tasks"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+" Clicked="OnAddTaskClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Row 0: Search -->
        <Entry Grid.Row="0" x:Name="SearchEntry" Placeholder="Search tasks..."
               ReturnType="Search" TextChanged="OnSearchTextChanged"
               Margin="10,5" BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
               TextColor="{AppThemeBinding Light=Black, Dark=White}" />

        <!-- Row 1: Filter chips -->
        <HorizontalStackLayout Grid.Row="1" Spacing="8" Padding="10,0,10,5">
            <Button x:Name="FilterPending" Text="Pending" CornerRadius="16" Padding="12,6"
                    FontSize="13" Clicked="OnFilterPendingClicked"
                    BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}" TextColor="White" />
            <Button x:Name="FilterAll" Text="All" CornerRadius="16" Padding="12,6"
                    FontSize="13" Clicked="OnFilterAllClicked"
                    BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#555555}"
                    TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}" />
        </HorizontalStackLayout>

        <!-- Row 2: States -->
        <ActivityIndicator x:Name="LoadingIndicator" Grid.Row="2" IsRunning="True" IsVisible="True"
                           VerticalOptions="Center" Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <VerticalStackLayout x:Name="EmptyState" Grid.Row="2" IsVisible="False"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Padding="20">
            <Label Text="No tasks found" FontSize="16" HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
            <Label Text="Tap + to create a new task" FontSize="13" HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#999999, Dark=#666666}" />
        </VerticalStackLayout>

        <RefreshView x:Name="RefreshContainer" Grid.Row="2" IsVisible="False" Refreshing="OnRefreshing">
            <CollectionView x:Name="TasksCollection">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>
                            <SwipeView.LeftItems>
                                <SwipeItem Text="Complete" BackgroundColor="#4CAF50"
                                           Invoked="OnCompleteSwiped" />
                            </SwipeView.LeftItems>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Delete" BackgroundColor="#D32F2F"
                                               Invoked="OnDeleteSwiped" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Margin="10,4" Padding="12" StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,1" Radius="3" Opacity="0.08" />
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTaskTapped" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted}"
                                              CheckedChanged="OnCheckChanged"
                                              Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"
                                              VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Description}" FontSize="15"
                                               TextDecorations="{Binding StrikethroughDecoration}"
                                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                        <HorizontalStackLayout Spacing="6">
                                            <Border Padding="4,1" StrokeShape="RoundRectangle 4"
                                                    Stroke="Transparent"
                                                    BackgroundColor="{Binding TaskTypeColor}">
                                                <Label Text="{Binding TaskTypeName}" FontSize="10"
                                                       TextColor="White" />
                                            </Border>
                                            <Label Text="{Binding DateDisplay}" FontSize="11"
                                                   TextColor="{AppThemeBinding Light=#888888, Dark=#999999}" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" FontSize="22" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#BDBDBD, Dark=#616161}" />
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>

</ContentPage>
