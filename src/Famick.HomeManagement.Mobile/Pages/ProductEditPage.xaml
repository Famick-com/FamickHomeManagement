<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.ProductEditPage"
             Title="Product"
             Shell.NavBarIsVisible="True"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Shell.TitleView>
        <Label x:Name="TitleLabel"
               Text="Edit Product"
               FontSize="18"
               FontAttributes="Bold"
               VerticalOptions="Center"
               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
    </Shell.TitleView>

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="SaveToolbarItem" Text="Save" Clicked="OnSaveClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*">
        <!-- Loading -->
        <ActivityIndicator x:Name="LoadingIndicator"
                           IsRunning="False"
                           IsVisible="False"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <!-- Content -->
        <ScrollView x:Name="ContentScroll">
            <VerticalStackLayout Padding="15" Spacing="12">

                <!-- Lookup Search Section (Create mode only) -->
                <VerticalStackLayout x:Name="LookupSection" IsVisible="False" Spacing="8">
                    <Label Text="Search Integrations" FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Label Text="Search external sources to pre-fill product details" FontSize="13" TextColor="Gray" />

                    <Border Padding="8,4"
                            StrokeShape="RoundRectangle 8"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                        <Entry x:Name="LookupSearchEntry"
                               Placeholder="Search by name or barcode..."
                               FontSize="15"
                               BackgroundColor="Transparent"
                               TextChanged="OnLookupSearchTextChanged"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </Border>

                    <!-- Lookup Loading -->
                    <ActivityIndicator x:Name="LookupLoadingIndicator"
                                       IsVisible="False"
                                       IsRunning="False"
                                       HeightRequest="30"
                                       Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

                    <!-- Selected Lookup Result -->
                    <Border x:Name="SelectedLookupBorder"
                            IsVisible="False"
                            Padding="10,8"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B5E20}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Label x:Name="SelectedLookupLabel"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#2E7D32, Dark=#A5D6A7}" />
                            <Button Grid.Column="1"
                                    Text="Clear"
                                    FontSize="12"
                                    HeightRequest="30"
                                    Padding="8,0"
                                    CornerRadius="6"
                                    BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                                    TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                                    Clicked="OnClearLookupResultClicked" />
                        </Grid>
                    </Border>

                    <!-- Lookup Results -->
                    <CollectionView x:Name="LookupResultsCollection"
                                    IsVisible="False"
                                    MaximumHeightRequest="300"
                                    SelectionMode="Single"
                                    SelectionChanged="OnLookupResultSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="0,2"
                                        StrokeShape="RoundRectangle 8"
                                        Stroke="Transparent"
                                        BackgroundColor="{AppThemeBinding Light=White, Dark=#333333}">
                                    <Border.Shadow>
                                        <Shadow Brush="{AppThemeBinding Light=#40000000, Dark=#20000000}"
                                                Offset="0,1" Radius="3" Opacity="0.08" />
                                    </Border.Shadow>
                                    <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="10" RowSpacing="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Thumbnail -->
                                        <Border Grid.RowSpan="2"
                                                HeightRequest="44" WidthRequest="44"
                                                StrokeShape="RoundRectangle 6"
                                                Stroke="Transparent"
                                                BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#3A3A3A}"
                                                VerticalOptions="Center">
                                            <Image Source="{Binding ThumbnailUrl}"
                                                   HeightRequest="44" WidthRequest="44"
                                                   Aspect="AspectFill" />
                                        </Border>

                                        <!-- Name -->
                                        <Label Grid.Column="1" Grid.Row="0"
                                               Text="{Binding Name}"
                                               FontSize="14" FontAttributes="Bold"
                                               LineBreakMode="TailTruncation"
                                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                                        <!-- Brand + Source -->
                                        <Label Grid.Column="1" Grid.Row="1"
                                               FontSize="12"
                                               LineBreakMode="TailTruncation"
                                               TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding Brand}" />
                                                    <Span Text=" - " />
                                                    <Span Text="{Binding PluginDisplayName}" FontAttributes="Italic" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>

                                        <!-- Price -->
                                        <Label Grid.Column="2" Grid.RowSpan="2"
                                               Text="{Binding Price, StringFormat='${0:F2}'}"
                                               FontSize="13"
                                               VerticalOptions="Center"
                                               IsVisible="{Binding HasPrice}"
                                               TextColor="{AppThemeBinding Light=#2E7D32, Dark=#A5D6A7}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <CollectionView.EmptyView>
                            <Label Text="No results found"
                                   FontSize="14"
                                   HorizontalOptions="Center"
                                   Padding="0,10"
                                   TextColor="{AppThemeBinding Light=#999999, Dark=#777777}" />
                        </CollectionView.EmptyView>
                    </CollectionView>

                    <!-- Divider -->
                    <Grid ColumnDefinitions="*,Auto,*" Padding="0,4">
                        <BoxView Grid.Column="0" HeightRequest="1" VerticalOptions="Center"
                                 BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />
                        <Label Grid.Column="1" Text="  or enter details manually  " FontSize="12"
                               TextColor="Gray" VerticalOptions="Center" />
                        <BoxView Grid.Column="2" HeightRequest="1" VerticalOptions="Center"
                                 BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />
                    </Grid>
                </VerticalStackLayout>

                <!-- Name -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Name *" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="NameEntry" Placeholder="Product name"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Description -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Description" FontSize="13" TextColor="Gray" />
                    <Editor x:Name="DescriptionEditor"
                            Placeholder="Optional description..."
                            HeightRequest="80"
                            AutoSize="TextChanges"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Active -->
                <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                    <Label Text="Active" FontSize="15" VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Switch x:Name="IsActiveSwitch" Grid.Column="1"
                            OnColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />
                </Grid>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />

                <!-- Location & Units Section -->
                <Label Text="Location &amp; Units" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <!-- Default Location -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Default Location *" FontSize="13" TextColor="Gray" />
                    <Picker x:Name="LocationPicker"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Product Group -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Product Group" FontSize="13" TextColor="Gray" />
                    <Picker x:Name="ProductGroupPicker"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Purchase Unit -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Purchase Unit *" FontSize="13" TextColor="Gray" />
                    <Picker x:Name="PurchaseUnitPicker"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Stock Unit -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Stock Unit *" FontSize="13" TextColor="Gray" />
                    <Picker x:Name="StockUnitPicker"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Factor -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Purchase to Stock Factor" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="FactorEntry" Placeholder="1" Keyboard="Numeric"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />

                <!-- Parent Product -->
                <Label Text="Parent Product" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="Parent Product (for variants)" FontSize="13" TextColor="Gray" />
                    <Border Padding="8,4"
                            StrokeShape="RoundRectangle 8"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry x:Name="ParentProductSearch"
                                   Placeholder="Search for parent product..."
                                   BackgroundColor="Transparent"
                                   TextChanged="OnParentSearchTextChanged"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            <Button x:Name="ClearParentButton"
                                    Grid.Column="1"
                                    Text="Clear"
                                    FontSize="12"
                                    HeightRequest="30"
                                    Padding="8,0"
                                    CornerRadius="6"
                                    IsVisible="False"
                                    BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                                    TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                                    Clicked="OnClearParentClicked" />
                        </Grid>
                    </Border>

                    <!-- Selected parent display -->
                    <Border x:Name="SelectedParentBorder"
                            IsVisible="False"
                            Padding="10,8"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1A237E}">
                        <Label x:Name="SelectedParentLabel"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#1565C0, Dark=#90CAF9}" />
                    </Border>

                    <!-- Autocomplete results -->
                    <CollectionView x:Name="ParentSearchResults"
                                    IsVisible="False"
                                    MaximumHeightRequest="200"
                                    SelectionMode="Single"
                                    SelectionChanged="OnParentProductSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="0,1"
                                        StrokeShape="RoundRectangle 6"
                                        Stroke="Transparent"
                                        BackgroundColor="{AppThemeBinding Light=White, Dark=#333333}">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <VerticalStackLayout Spacing="0">
                                            <Label Text="{Binding Name}"
                                                   FontSize="14"
                                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                            <Label Text="{Binding ProductGroupName}"
                                                   FontSize="11"
                                                   TextColor="Gray" />
                                        </VerticalStackLayout>
                                        <Border Grid.Column="1"
                                                Padding="6,2"
                                                StrokeShape="RoundRectangle 4"
                                                Stroke="#42A5F5"
                                                BackgroundColor="Transparent"
                                                IsVisible="{Binding IsMasterCatalog}">
                                            <Label Text="Catalog"
                                                   FontSize="10"
                                                   TextColor="#42A5F5" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />

                <!-- Stock Settings -->
                <Label Text="Stock Settings" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <!-- Min Stock Amount -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Minimum Stock Amount" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="MinStockEntry" Placeholder="0" Keyboard="Numeric"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Tracks Best Before -->
                <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                    <Label Text="Track best before date" FontSize="15" VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Switch x:Name="TracksBestBeforeSwitch" Grid.Column="1"
                            Toggled="OnTracksBestBeforeToggled"
                            OnColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />
                </Grid>

                <!-- Default Best Before Days -->
                <VerticalStackLayout x:Name="BestBeforeDaysSection" Spacing="4" IsVisible="False">
                    <Label Text="Default Best Before Days" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="BestBeforeDaysEntry" Placeholder="0" Keyboard="Numeric"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Expiry Warning Days -->
                <VerticalStackLayout x:Name="ExpiryWarningSection" Spacing="4" IsVisible="False">
                    <Label Text="Expiry Warning Days (override)" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="ExpiryWarningDaysEntry" Placeholder="Leave blank for default" Keyboard="Numeric"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Bottom spacing -->
                <BoxView HeightRequest="20" BackgroundColor="Transparent" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
