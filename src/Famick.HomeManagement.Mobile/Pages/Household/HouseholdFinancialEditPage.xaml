<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.Household.HouseholdFinancialEditPage"
             Title="Edit Financial"
             Shell.NavBarIsVisible="True"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Shell.TitleView>
        <Label Text="Edit Financial Info"
               FontSize="18" FontAttributes="Bold" VerticalOptions="Center"
               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
    </Shell.TitleView>

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="SaveToolbarItem" Text="Save" Clicked="OnSaveClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*">
        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" IsVisible="True"
                           VerticalOptions="Center" HorizontalOptions="Center"
                           Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <ScrollView x:Name="ContentScroll" IsVisible="False">
            <VerticalStackLayout Padding="15" Spacing="12">

                <Label Text="Insurance" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="Insurance Type" FontSize="13" TextColor="Gray" />
                    <Picker x:Name="InsuranceTypePicker"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}">
                        <Picker.Items>
                            <x:String>Homeowners</x:String>
                            <x:String>Renters</x:String>
                        </Picker.Items>
                    </Picker>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Policy Number" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="PolicyNumberEntry" Placeholder="Policy number"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Agent Name" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="AgentNameEntry" Placeholder="Agent name"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Agent Phone" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="AgentPhoneEntry" Placeholder="Agent phone" Keyboard="Telephone"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Agent Email" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="AgentEmailEntry" Placeholder="Agent email" Keyboard="Email"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />

                <Label Text="Financial" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="Mortgage Info" FontSize="13" TextColor="Gray" />
                    <Editor x:Name="MortgageEditor" Placeholder="Lender, account, details..."
                            HeightRequest="80" AutoSize="TextChanges"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Property Tax Account #" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="TaxAccountEntry" Placeholder="Tax account number"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Appraisal Value" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="AppraisalValueEntry" Placeholder="e.g. 350000" Keyboard="Numeric"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Appraisal Date" FontSize="13" TextColor="Gray" />
                    <DatePicker x:Name="AppraisalDatePicker"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Escrow Details" FontSize="13" TextColor="Gray" />
                    <Editor x:Name="EscrowEditor" Placeholder="Escrow details..."
                            HeightRequest="80" AutoSize="TextChanges"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <BoxView HeightRequest="20" BackgroundColor="Transparent" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
