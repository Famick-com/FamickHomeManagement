<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sfAvatar="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             x:Class="Famick.HomeManagement.Mobile.Pages.Household.HouseholdOverviewEditPage"
             Title="Edit Overview"
             Shell.NavBarIsVisible="True"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Shell.TitleView>
        <Label Text="Edit Property Details"
               FontSize="18" FontAttributes="Bold" VerticalOptions="Center"
               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
    </Shell.TitleView>

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="SaveToolbarItem" Text="Save" Clicked="OnSaveClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*">
        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" IsVisible="True"
                           VerticalOptions="Center" HorizontalOptions="Center"
                           Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <ScrollView x:Name="ContentScroll" IsVisible="False">
            <VerticalStackLayout Padding="15" Spacing="12">

                <!-- Household Profile Image -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Grid WidthRequest="100" HeightRequest="100" HorizontalOptions="Center">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnProfileImageTapped" />
                        </Grid.GestureRecognizers>
                        <sfAvatar:SfAvatarView x:Name="AvatarView"
                                               WidthRequest="100" HeightRequest="100"
                                               AvatarShape="Circle"
                                               ContentType="Initials"
                                               AvatarName="🏠"
                                               BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                                               InitialsColor="{AppThemeBinding Light=#616161, Dark=#BDBDBD}"
                                               FontSize="36"
                                               Stroke="Transparent"
                                               StrokeThickness="0" />
                        <Border WidthRequest="28" HeightRequest="28"
                                StrokeShape="RoundRectangle 14"
                                Stroke="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                                StrokeThickness="2"
                                BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#64B5F6}"
                                HorizontalOptions="End" VerticalOptions="End"
                                Margin="0,0,2,2">
                            <Label Text="&#x270E;" FontSize="14" TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                    <Label Text="Tap to set photo" FontSize="12"
                           TextColor="{AppThemeBinding Light=#999999, Dark=#666666}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />

                <Label Text="Property Details" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="Unit" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="UnitEntry" Placeholder="e.g. Apt 4B"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Year Built" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="YearBuiltEntry" Placeholder="e.g. 1995" Keyboard="Numeric"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Square Footage" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="SqFtEntry" Placeholder="e.g. 2400" Keyboard="Numeric"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Bedrooms" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="BedroomsEntry" Placeholder="e.g. 3" Keyboard="Numeric"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Bathrooms" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="BathroomsEntry" Placeholder="e.g. 2.5" Keyboard="Numeric"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />

                <Label Text="HOA" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="HOA Name" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="HoaNameEntry" Placeholder="HOA name"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Contact Info" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="HoaContactEntry" Placeholder="Phone, email, or website"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Rules Link" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="HoaRulesEntry" Placeholder="https://..." Keyboard="Url"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <BoxView HeightRequest="20" BackgroundColor="Transparent" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
