<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.Household.HouseholdFinancialPage"
             Title="Financial"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Edit" Clicked="OnEditClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*">
        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" IsVisible="True"
                           VerticalOptions="Center" HorizontalOptions="Center"
                           Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <VerticalStackLayout x:Name="EmptyState" IsVisible="False"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Padding="20">
            <Label Text="No home data found" FontSize="16" HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
        </VerticalStackLayout>

        <RefreshView x:Name="RefreshContainer" IsVisible="False" Refreshing="OnRefreshing">
            <ScrollView>
                <VerticalStackLayout Padding="15" Spacing="12">

                    <!-- Insurance Section -->
                    <Label Text="Insurance" FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                    <Border Padding="16" StrokeShape="RoundRectangle 10" Stroke="Transparent"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,1" Radius="3" Opacity="0.08" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="16">
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                                <Label Text="Type" FontSize="12" TextColor="Gray" />
                                <Label x:Name="InsuranceTypeLabel" FontSize="15"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
                                <Label Text="Policy Number" FontSize="12" TextColor="Gray" />
                                <Label x:Name="PolicyNumberLabel" FontSize="15"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="2">
                                <Label Text="Agent Name" FontSize="12" TextColor="Gray" />
                                <Label x:Name="AgentNameLabel" FontSize="15"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="2">
                                <Label Text="Agent Phone" FontSize="12" TextColor="Gray" />
                                <Label x:Name="AgentPhoneLabel" FontSize="15"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="2">
                                <Label Text="Agent Email" FontSize="12" TextColor="Gray" />
                                <Label x:Name="AgentEmailLabel" FontSize="15"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Financial Section -->
                    <Label Text="Financial" FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" Margin="0,8,0,0" />

                    <Border Padding="16" StrokeShape="RoundRectangle 10" Stroke="Transparent"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,1" Radius="3" Opacity="0.08" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Mortgage Info" FontSize="12" TextColor="Gray" />
                                <Label x:Name="MortgageLabel" FontSize="15"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            </VerticalStackLayout>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="Tax Account #" FontSize="12" TextColor="Gray" />
                                    <Label x:Name="TaxAccountLabel" FontSize="15"
                                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="Appraisal Value" FontSize="12" TextColor="Gray" />
                                    <Label x:Name="AppraisalValueLabel" FontSize="15"
                                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                </VerticalStackLayout>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="Appraisal Date" FontSize="12" TextColor="Gray" />
                                    <Label x:Name="AppraisalDateLabel" FontSize="15"
                                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                </VerticalStackLayout>
                            </Grid>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Escrow Details" FontSize="12" TextColor="Gray" />
                                <Label x:Name="EscrowLabel" FontSize="15"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <BoxView HeightRequest="20" BackgroundColor="Transparent" />
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
