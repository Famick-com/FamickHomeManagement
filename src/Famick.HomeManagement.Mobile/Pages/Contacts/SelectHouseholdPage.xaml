<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.Contacts.SelectHouseholdPage"
             Title="Select Household"
             Shell.NavBarIsVisible="True">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Prompt -->
        <Label Grid.Row="0" Text="Select a household to import to"
               FontSize="16" FontAttributes="Bold"
               HorizontalTextAlignment="Center"
               Margin="10,12,10,0"
               TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}" />

        <!-- Search -->
        <Entry x:Name="SearchEntry"
               Grid.Row="1"
               Placeholder="Search households..."
               ReturnType="Search"
               TextChanged="OnSearchTextChanged"
               Margin="10,10" />

        <!-- Loading Indicator -->
        <ActivityIndicator x:Name="LoadingIndicator"
                           Grid.Row="2"
                           IsRunning="True"
                           IsVisible="True"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <!-- Error State -->
        <Frame x:Name="ErrorFrame" Grid.Row="2" IsVisible="False"
               Padding="20" Margin="20" CornerRadius="8"
               BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#3E2723}"
               BorderColor="Transparent" HasShadow="False"
               VerticalOptions="Center">
            <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                <Label x:Name="ErrorLabel" FontSize="16" HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light=#E65100, Dark=#FFB74D}" />
                <Button Text="Retry" Clicked="OnRetryClicked"
                        BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"
                        TextColor="White" CornerRadius="8" />
            </VerticalStackLayout>
        </Frame>

        <!-- Empty State -->
        <VerticalStackLayout x:Name="EmptyState" Grid.Row="2" IsVisible="False"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
            <Label Text="No households found" FontSize="16" HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=#757575, Dark=#9E9E9E}" />
        </VerticalStackLayout>

        <!-- Household List -->
        <CollectionView x:Name="HouseholdsList"
                        Grid.Row="2"
                        IsVisible="False"
                        SelectionMode="Single"
                        SelectionChanged="OnHouseholdSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12" Margin="8,4" CornerRadius="8" BorderColor="Transparent"
                           HasShadow="False"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                        <HorizontalStackLayout Spacing="12">
                            <!-- Initials Avatar -->
                            <Border WidthRequest="44" HeightRequest="44"
                                    StrokeShape="RoundRectangle 22"
                                    Stroke="Transparent"
                                    BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1A237E}">
                                <Label Text="{Binding Initials}" FontSize="16" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding GroupName}" FontSize="16" FontAttributes="Bold" />
                                <Label Text="{Binding PrimaryAddress}" FontSize="12"
                                       TextColor="{AppThemeBinding Light=#757575, Dark=#9E9E9E}"
                                       LineBreakMode="TailTruncation" MaxLines="1" />
                                <Label FontSize="12"
                                       TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding MemberCount}" />
                                            <Span Text=" members" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
