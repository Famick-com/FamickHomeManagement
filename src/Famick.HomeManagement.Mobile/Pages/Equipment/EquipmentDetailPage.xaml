<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.Equipment.EquipmentDetailPage"
             Title="Equipment"
             Shell.NavBarIsVisible="True">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Edit" Clicked="OnEditClicked" IconImageSource="pencil" />
    </ContentPage.ToolbarItems>

    <Grid>
        <!-- Loading -->
        <ActivityIndicator x:Name="LoadingIndicator"
                           IsRunning="True" IsVisible="True"
                           VerticalOptions="Center" HorizontalOptions="Center"
                           Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <!-- Error -->
        <Border x:Name="ErrorFrame" IsVisible="False" Margin="20" Padding="20"
                StrokeShape="RoundRectangle 10" Stroke="Transparent" BackgroundColor="#FFEBEE"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="10">
                <Label x:Name="ErrorLabel" TextColor="#C62828" HorizontalOptions="Center" />
                <Button Text="Retry" Clicked="OnRetryClicked" />
            </VerticalStackLayout>
        </Border>

        <!-- Content -->
        <ScrollView x:Name="ContentScroll" IsVisible="False">
            <VerticalStackLayout Spacing="0" Padding="15">

                <!-- Title + Icon -->
                <HorizontalStackLayout Spacing="10" Margin="0,0,0,8">
                    <Border WidthRequest="44" HeightRequest="44"
                            StrokeShape="RoundRectangle 22" Stroke="Transparent"
                            BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1A237E}"
                            VerticalOptions="Center">
                        <Image Source="flyout_equipment" WidthRequest="22" HeightRequest="22"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                        <Label x:Name="TitleLabel" FontSize="24" FontAttributes="Bold" />
                        <Label x:Name="CategoryLabel" FontSize="13" TextColor="Gray" IsVisible="False" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- Warranty Badge -->
                <Border x:Name="WarrantyBadge" IsVisible="False" Padding="8,4" Margin="0,0,0,8"
                        StrokeShape="RoundRectangle 8" Stroke="Transparent" HorizontalOptions="Start">
                    <Label x:Name="WarrantyBadgeLabel" FontSize="12" FontAttributes="Bold" />
                </Border>

                <!-- Description -->
                <Border x:Name="DescriptionSection" IsVisible="False" Padding="12" Margin="0,0,0,12"
                        StrokeShape="RoundRectangle 10" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Description" FontSize="13" FontAttributes="Bold" TextColor="Gray" />
                        <Label x:Name="DescriptionLabel" FontSize="14"
                               TextColor="{AppThemeBinding Light=#424242, Dark=#BDBDBD}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Details Card -->
                <Border Padding="12" Margin="0,0,0,12" StrokeShape="RoundRectangle 10" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <VerticalStackLayout x:Name="DetailsStack" Spacing="6" />
                </Border>

                <!-- Warranty Card -->
                <Border x:Name="WarrantySection" IsVisible="False" Padding="12" Margin="0,0,0,12"
                        StrokeShape="RoundRectangle 10" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <VerticalStackLayout x:Name="WarrantyStack" Spacing="6">
                        <Label Text="Warranty" FontSize="14" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Notes -->
                <Border x:Name="NotesSection" IsVisible="False" Padding="12" Margin="0,0,0,12"
                        StrokeShape="RoundRectangle 10" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Notes" FontSize="13" FontAttributes="Bold" TextColor="Gray" />
                        <Label x:Name="NotesLabel" FontSize="14"
                               TextColor="{AppThemeBinding Light=#424242, Dark=#BDBDBD}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Documents Section -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,4">
                    <Label Text="Documents" FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="+ Add" Clicked="OnAddDocumentClicked"
                            FontSize="13" Padding="10,4" CornerRadius="14"
                            BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}" TextColor="White" />
                </Grid>
                <VerticalStackLayout x:Name="DocumentsList" Spacing="6" />
                <Label x:Name="NoDocumentsLabel" Text="No documents" FontSize="13" TextColor="Gray"
                       HorizontalOptions="Center" Margin="0,6,0,12" IsVisible="False" />

                <!-- Usage Logs Section (only when UsageUnit is set) -->
                <VerticalStackLayout x:Name="UsageSection" IsVisible="False">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,4">
                        <Label x:Name="UsageSectionTitle" Text="Usage History" FontSize="16" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="+ Add" Clicked="OnAddUsageLogClicked"
                                FontSize="13" Padding="10,4" CornerRadius="14"
                                BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}" TextColor="White" />
                    </Grid>
                    <VerticalStackLayout x:Name="UsageLogsList" Spacing="6" />
                    <Label x:Name="NoUsageLogsLabel" Text="No usage logs" FontSize="13" TextColor="Gray"
                           HorizontalOptions="Center" Margin="0,6,0,12" IsVisible="False" />
                </VerticalStackLayout>

                <!-- Maintenance Records Section -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,4">
                    <Label Text="Maintenance History" FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="+ Add" Clicked="OnAddMaintenanceClicked"
                            FontSize="13" Padding="10,4" CornerRadius="14"
                            BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}" TextColor="White" />
                </Grid>
                <VerticalStackLayout x:Name="MaintenanceList" Spacing="6" />
                <Label x:Name="NoMaintenanceLabel" Text="No maintenance records" FontSize="13" TextColor="Gray"
                       HorizontalOptions="Center" Margin="0,6,0,12" IsVisible="False" />

                <!-- Delete Button -->
                <Button x:Name="DeleteButton" Text="Delete Equipment" Clicked="OnDeleteClicked"
                        Margin="0,20,0,20" BackgroundColor="#E53935" TextColor="White" CornerRadius="8" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
