<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.Equipment.EquipmentEditPage"
             Title="Equipment"
             Shell.NavBarIsVisible="True"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Shell.TitleView>
        <Label x:Name="TitleLabel" Text="New Equipment"
               FontSize="18" FontAttributes="Bold" VerticalOptions="Center"
               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
    </Shell.TitleView>

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="SaveToolbarItem" Text="Save" Clicked="OnSaveClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*">
        <!-- Loading -->
        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False"
                           VerticalOptions="Center" HorizontalOptions="Center"
                           Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <!-- Content -->
        <ScrollView x:Name="ContentScroll">
            <VerticalStackLayout Padding="15" Spacing="12">

                <!-- Name -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Name *" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="NameEntry" Placeholder="Equipment name"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Description -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Description" FontSize="13" TextColor="Gray" />
                    <Editor x:Name="DescriptionEditor" Placeholder="Optional description..."
                            HeightRequest="80" AutoSize="TextChanges"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Location -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Location" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="LocationEntry" Placeholder="e.g. Garage, Kitchen"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Category -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Category" FontSize="13" TextColor="Gray" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Picker x:Name="CategoryPicker"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Button Grid.Column="1" Text="+ New" Clicked="OnNewCategoryClicked"
                                FontSize="12" Padding="8,4" CornerRadius="12"
                                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                                TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}" />
                    </Grid>
                </VerticalStackLayout>

                <!-- Parent Equipment -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Parent Equipment" FontSize="13" TextColor="Gray" />
                    <Picker x:Name="ParentEquipmentPicker"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />

                <!-- Technical Section -->
                <Label Text="Technical Details" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="Manufacturer" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="ManufacturerEntry" Placeholder="Manufacturer name"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Manufacturer Link" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="ManufacturerLinkEntry" Placeholder="https://..."
                           Keyboard="Url"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Model Number" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="ModelNumberEntry" Placeholder="Model number"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Serial Number" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="SerialNumberEntry" Placeholder="Serial number"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />

                <!-- Purchase Section -->
                <Label Text="Purchase Info" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="Purchase Date" FontSize="13" TextColor="Gray" />
                    <DatePicker x:Name="PurchaseDatePicker"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                        <Label Text="Has purchase date" FontSize="13" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Switch x:Name="HasPurchaseDateSwitch" Grid.Column="1"
                                Toggled="OnHasPurchaseDateToggled"
                                OnColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Purchase Location" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="PurchaseLocationEntry" Placeholder="Where purchased"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />

                <!-- Warranty Section -->
                <Label Text="Warranty" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="Warranty Expiration" FontSize="13" TextColor="Gray" />
                    <DatePicker x:Name="WarrantyDatePicker"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                        <Label Text="Has warranty date" FontSize="13" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Switch x:Name="HasWarrantyDateSwitch" Grid.Column="1"
                                Toggled="OnHasWarrantyDateToggled"
                                OnColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Warranty Contact" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="WarrantyContactEntry" Placeholder="Contact info for warranty claims"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />

                <!-- Usage Tracking -->
                <Label Text="Usage Tracking" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="Usage Unit" FontSize="13" TextColor="Gray" />
                    <Entry x:Name="UsageUnitEntry" Placeholder="e.g. miles, hours, cycles (leave blank to disable)"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}" />

                <!-- Notes -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Notes" FontSize="13" TextColor="Gray" />
                    <Editor x:Name="NotesEditor" Placeholder="Additional notes..."
                            HeightRequest="100" AutoSize="TextChanges"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>

                <!-- Bottom spacing -->
                <BoxView HeightRequest="20" BackgroundColor="Transparent" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
