<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.ProductsListPage"
             Title="Products"
             Shell.NavBarIsVisible="True"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add" Clicked="OnAddProductClicked" IconImageSource="plus" />
    </ContentPage.ToolbarItems>

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Search Bar + Filter Chips -->
        <VerticalStackLayout Grid.Row="0" Spacing="12" Padding="15,15,15,8">
            <Border Padding="8,4"
                    StrokeShape="RoundRectangle 10"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                <Entry x:Name="SearchEntry"
                       Placeholder="Search products..."
                       FontSize="16"
                       BackgroundColor="Transparent"
                       TextChanged="OnSearchTextChanged"
                       Completed="OnSearchSubmitted" />
            </Border>

            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8">
                    <Button x:Name="FilterAllButton"
                            Text="All"
                            FontSize="13"
                            HeightRequest="34"
                            Padding="12,0"
                            CornerRadius="17"
                            BackgroundColor="#1976D2"
                            TextColor="White"
                            Clicked="OnFilterAllClicked" />
                    <Button x:Name="FilterActiveButton"
                            Text="Active"
                            FontSize="13"
                            HeightRequest="34"
                            Padding="12,0"
                            CornerRadius="17"
                            BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                            TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                            Clicked="OnFilterActiveClicked" />
                    <Button x:Name="FilterInactiveButton"
                            Text="Inactive"
                            FontSize="13"
                            HeightRequest="34"
                            Padding="12,0"
                            CornerRadius="17"
                            BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                            TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                            Clicked="OnFilterInactiveClicked" />
                    <Button x:Name="FilterLowStockButton"
                            Text="Low Stock"
                            FontSize="13"
                            HeightRequest="34"
                            Padding="12,0"
                            CornerRadius="17"
                            BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                            TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                            Clicked="OnFilterLowStockClicked" />
                </HorizontalStackLayout>
            </ScrollView>
        </VerticalStackLayout>

        <!-- Loading State (initial load) -->
        <ActivityIndicator x:Name="LoadingIndicator"
                           Grid.Row="1"
                           IsVisible="False"
                           IsRunning="False"
                           Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"
                           WidthRequest="40"
                           HeightRequest="40"
                           HorizontalOptions="Center"
                           VerticalOptions="Start"
                           Margin="0,20" />

        <!-- Product List with Infinite Scroll -->
        <RefreshView x:Name="ProductsRefreshView"
                     Grid.Row="1"
                     IsRefreshing="{Binding IsRefreshing}"
                     Refreshing="OnRefreshing">
            <CollectionView x:Name="ProductsCollection"
                            SelectionMode="Single"
                            SelectionChanged="OnProductSelected"
                            RemainingItemsThreshold="5"
                            RemainingItemsThresholdReached="OnLoadMoreProducts"
                            ItemSizingStrategy="MeasureAllItems">
                <CollectionView.Header>
                    <BoxView HeightRequest="4" Color="Transparent" />
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" Margin="15,3"
                                StrokeShape="RoundRectangle 10"
                                Stroke="Transparent"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light=#40000000, Dark=#20000000}"
                                        Offset="0,1"
                                        Radius="4"
                                        Opacity="0.1" />
                            </Border.Shadow>
                            <Grid ColumnSpacing="10" RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Product Image -->
                                <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3"
                                        HeightRequest="50" WidthRequest="50"
                                        StrokeShape="RoundRectangle 8"
                                        Stroke="Transparent"
                                        BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#3A3A3A}"
                                        VerticalOptions="Start">
                                    <Image Source="{Binding ImageSource}"
                                           HeightRequest="50" WidthRequest="50"
                                           Aspect="AspectFill"
                                           IsVisible="{Binding HasImage}" />
                                </Border>

                                <!-- Product Name -->
                                <Label Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                       Text="{Binding Name}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                                <!-- Stock Amount + Product Group -->
                                <Label Grid.Row="1" Grid.Column="1"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light=#444444, Dark=#CCCCCC}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding StockDisplay}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Label Grid.Row="1" Grid.Column="2"
                                       Text="{Binding ProductGroupName}"
                                       FontSize="12"
                                       HorizontalOptions="End"
                                       IsVisible="{Binding HasProductGroup}"
                                       TextColor="{AppThemeBinding Light=#888888, Dark=#999999}" />

                                <!-- Status Badges -->
                                <HorizontalStackLayout Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                                       Spacing="6">
                                    <Border Padding="6,2"
                                            StrokeShape="RoundRectangle 4"
                                            Stroke="Transparent"
                                            BackgroundColor="#E91E63"
                                            IsVisible="{Binding IsBelowMinStock}">
                                        <Label Text="LOW STOCK" FontSize="10" TextColor="White" FontAttributes="Bold" />
                                    </Border>

                                    <Border Padding="6,2"
                                            StrokeShape="RoundRectangle 4"
                                            Stroke="Transparent"
                                            BackgroundColor="#9E9E9E"
                                            IsVisible="{Binding IsInactive}">
                                        <Label Text="INACTIVE" FontSize="10" TextColor="White" FontAttributes="Bold" />
                                    </Border>
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <VerticalStackLayout>
                        <ActivityIndicator x:Name="LoadMoreIndicator"
                                           IsVisible="False"
                                           IsRunning="False"
                                           Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"
                                           WidthRequest="30"
                                           HeightRequest="30"
                                           HorizontalOptions="Center"
                                           Margin="0,10" />
                        <BoxView HeightRequest="15" Color="Transparent" />
                    </VerticalStackLayout>
                </CollectionView.Footer>

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="10"
                                         Padding="30">
                        <Label Text="No products found"
                               FontSize="18"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                        <Label Text="Try adjusting your search or filters"
                               FontSize="14"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#999999, Dark=#777777}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
