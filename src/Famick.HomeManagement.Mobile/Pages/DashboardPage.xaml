<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.DashboardPage"
             Title="Dashboard"
             Shell.NavBarIsVisible="True">

    <Grid>
        <!-- Offline Banner -->
        <Border x:Name="OfflineBanner"
                IsVisible="False"
                Padding="10"
                Margin="0"
                StrokeShape="RoundRectangle 0"
                Stroke="Transparent"
                StrokeThickness="0"
                BackgroundColor="#FFF3E0"
                VerticalOptions="Start"
                ZIndex="50">
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Text="Offline" FontAttributes="Bold" TextColor="#E65100" VerticalOptions="Center" />
                <Label Text="Unable to reach server" FontSize="12" TextColor="#F57C00" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <RefreshView x:Name="RefreshContainer" Refreshing="OnRefreshing">
            <ScrollView>
                <Grid Padding="15" RowSpacing="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Loading Indicator (overlays content) -->
                <ActivityIndicator x:Name="LoadingIndicator"
                                   Grid.Row="0"
                                   Grid.RowSpan="10"
                                   IsRunning="False"
                                   IsVisible="False"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"
                                   Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"
                                   ZIndex="100" />

                <!-- Home Setup Wizard Banner (conditionally visible) -->
                <Border x:Name="WizardBanner"
                        Grid.Row="0"
                        IsVisible="False"
                        Padding="15"
                        StrokeShape="RoundRectangle 12"
                        Stroke="#1976D2"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1A237E}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnWizardBannerTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="&#127968;" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Complete Home Setup"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1565C0, Dark=#90CAF9}" />
                            <Label Text="Finish setting up your home to unlock all features"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#1976D2, Dark=#64B5F6}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="&#8250;" FontSize="24"
                               TextColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Tasks Banner (conditionally visible) -->
                <Border x:Name="TasksBanner"
                        Grid.Row="0"
                        IsVisible="False"
                        Padding="15"
                        StrokeShape="RoundRectangle 12"
                        Stroke="#FF9800"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#3E2723}"
                        Margin="0,5,0,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTasksBannerTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="&#9745;" FontSize="24" VerticalOptions="Center"
                               TextColor="#FF9800" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label x:Name="TasksBannerTitle"
                                   Text="You Have Tasks To Complete"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#E65100, Dark=#FFB74D}" />
                            <Label Text="Tap to review new products"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#F57C00, Dark=#FF9800}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="&#8250;" FontSize="24"
                               TextColor="{AppThemeBinding Light=#FF9800, Dark=#FFB74D}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Shopping Banner -->
                <Border x:Name="ShoppingBanner" Grid.Row="1"
                        IsVisible="False"
                        Padding="15"
                        StrokeShape="RoundRectangle 12"
                        Stroke="#1976D2"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1A237E}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnShoppingCardTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="&#128722;" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label x:Name="ShoppingBannerTitle"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1565C0, Dark=#90CAF9}" />
                            <Label x:Name="ShoppingBannerSubtitle"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#1976D2, Dark=#64B5F6}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="&#8250;" FontSize="24"
                               TextColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Low Stock Banner -->
                <Border x:Name="LowStockBanner" Grid.Row="2"
                        IsVisible="False"
                        Padding="15"
                        StrokeShape="RoundRectangle 12"
                        Stroke="#F9A825"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=#FFF8E1, Dark=#3E2723}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnStockCardTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="&#9888;" FontSize="24" VerticalOptions="Center"
                               TextColor="#F9A825" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label x:Name="LowStockBannerTitle"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#F57F17, Dark=#FFD54F}" />
                            <Label x:Name="LowStockBannerSubtitle"
                                   Text="Tap to view details"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#F9A825, Dark=#FFCA28}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="&#8250;" FontSize="24"
                               TextColor="{AppThemeBinding Light=#F9A825, Dark=#FFD54F}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Chores Banner -->
                <Border x:Name="ChoresBanner" Grid.Row="3"
                        IsVisible="False"
                        Padding="15"
                        StrokeShape="RoundRectangle 12"
                        Stroke="#1976D2"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1A237E}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnChoresCardTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="&#128467;" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label x:Name="ChoresBannerTitle"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1565C0, Dark=#90CAF9}" />
                            <Label x:Name="ChoresBannerSubtitle"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#1976D2, Dark=#64B5F6}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="&#8250;" FontSize="24"
                               TextColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Expiring Soon Banner -->
                <Border x:Name="ExpiringBanner" Grid.Row="4"
                        IsVisible="False"
                        Padding="15"
                        StrokeShape="RoundRectangle 12"
                        Stroke="#E65100"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#3E2723}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnExpiringCardTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="&#128197;" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label x:Name="ExpiringBannerTitle"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#E65100, Dark=#FF9800}" />
                            <Label x:Name="ExpiringBannerSubtitle"
                                   Text="Tap to view details"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#F57C00, Dark=#FFB74D}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="&#8250;" FontSize="24"
                               TextColor="{AppThemeBinding Light=#E65100, Dark=#FF9800}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Overdue Chores Alert (conditionally visible) -->
                <Border Grid.Row="5"
                        x:Name="OverdueChoresAlert"
                        IsVisible="False"
                        Padding="15"
                        StrokeShape="RoundRectangle 12"
                        Stroke="#E53935"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#4A1C1C}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnChoresCardTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0"
                               Text="&#9888;"
                               FontSize="24"
                               TextColor="#E53935"
                               VerticalOptions="Center" />

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label x:Name="OverdueChoresTitle"
                                   Text="Overdue Chores"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#E53935" />
                            <Label x:Name="OverdueChoresSubtitle"
                                   Text="You have chores that need attention"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#C62828, Dark=#EF5350}" />
                        </VerticalStackLayout>

                        <Label Grid.Column="2"
                               Text="&#8250;"
                               FontSize="24"
                               TextColor="#E53935"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Upcoming Events Widget -->
                <Border Grid.Row="6"
                        x:Name="UpcomingEventsSection"
                        IsVisible="False"
                        Padding="15"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnUpcomingEventsTapped" />
                    </Border.GestureRecognizers>
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Light=#40000000, Dark=#20000000}"
                                Offset="0,2"
                                Radius="8"
                                Opacity="0.15" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Label Text="Upcoming Events"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            <Label Grid.Column="1"
                                   Text="View All ›"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#518751, Dark=#6B9E6B}"
                                   VerticalOptions="Center" />
                        </Grid>
                        <VerticalStackLayout x:Name="UpcomingEventsList" Spacing="6" />
                        <Label x:Name="NoEventsLabel"
                               Text="No upcoming events"
                               FontSize="13"
                               TextColor="Gray"
                               IsVisible="False" />
                    </VerticalStackLayout>
                </Border>

                <!-- Today's Meals Widget -->
                <Border Grid.Row="7"
                        x:Name="TodaysMealsSection"
                        IsVisible="False"
                        Padding="15"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTodaysMealsTapped" />
                    </Border.GestureRecognizers>
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Light=#40000000, Dark=#20000000}"
                                Offset="0,2"
                                Radius="8"
                                Opacity="0.15" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Label Text="🍽️" FontSize="20" VerticalOptions="Center" Margin="0,0,8,0" />
                            <Label Grid.Column="1"
                                   Text="Today's Meals"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            <Label Grid.Column="2"
                                   Text="View Plan ›"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#518751, Dark=#6B9E6B}"
                                   VerticalOptions="Center" />
                        </Grid>
                        <VerticalStackLayout x:Name="TodaysMealsList" Spacing="4" />
                        <Label x:Name="NoMealsPlannedLabel"
                               Text="No meals planned for today"
                               FontSize="13"
                               TextColor="Gray"
                               IsVisible="False" />
                    </VerticalStackLayout>
                </Border>

                <!-- Quick Consume Button -->
                <Button Grid.Row="8"
                        Text="Quick Consume"
                        Clicked="OnQuickConsumeClicked"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        CornerRadius="10" />

                <!-- Error Message -->
                <Border x:Name="ErrorAlert"
                        Grid.Row="9"
                        IsVisible="False"
                        Padding="15"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        BackgroundColor="#FFEBEE"
                        VerticalOptions="Start">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="ErrorLabel"
                               Text="Failed to load dashboard"
                               TextColor="#C62828"
                               HorizontalOptions="Center" />
                        <Button Text="Retry"
                                Clicked="OnRetryClicked"
                                BackgroundColor="#E53935"
                                TextColor="White" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
