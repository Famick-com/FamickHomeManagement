<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.AcceptTermsPage"
             Title="Terms &amp; Privacy"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

            <!-- App Logo -->
            <Image Source="famick_logo"
                   Aspect="AspectFit"
                   HeightRequest="80"
                   HorizontalOptions="Center" />

            <!-- Title -->
            <Label Text="Terms of Service &amp; Privacy Policy"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

            <Label Text="Please review and accept our Terms of Service and Privacy Policy to continue using Famick."
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}"
                   Margin="0,0,0,10" />

            <!-- Links -->
            <Frame Padding="15" CornerRadius="10" HasShadow="False"
                   BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                <VerticalStackLayout Spacing="15">

                    <Label Text="Terms of Service"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light=#1976D2, Dark=#64B5F6}"
                           TextDecorations="Underline"
                           HorizontalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTermsTapped" />
                        </Label.GestureRecognizers>
                    </Label>

                    <Label Text="Privacy Policy"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light=#1976D2, Dark=#64B5F6}"
                           TextDecorations="Underline"
                           HorizontalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPrivacyTapped" />
                        </Label.GestureRecognizers>
                    </Label>

                </VerticalStackLayout>
            </Frame>

            <!-- Consent Checkbox -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <CheckBox x:Name="ConsentCheckBox"
                          Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />
                <Label Text="I agree to the Terms of Service and Privacy Policy"
                       FontSize="14"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}" />
            </HorizontalStackLayout>

            <!-- Error Message -->
            <Label x:Name="ErrorLabel"
                   TextColor="Red"
                   FontSize="14"
                   HorizontalOptions="Center"
                   IsVisible="False" />

            <!-- Accept Button -->
            <Button x:Name="AcceptButton"
                    Text="Accept &amp; Continue"
                    Clicked="OnAcceptClicked"
                    BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}"
                    TextColor="White"
                    FontSize="18"
                    HeightRequest="50"
                    CornerRadius="25" />

            <!-- Loading Indicator -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False"
                               IsVisible="False"
                               Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
