<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.Stores.StoresListPage"
             Title="Stores"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+" Clicked="OnAddClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*">
        <!-- Loading -->
        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" IsVisible="True"
                           VerticalOptions="Center" Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <!-- Empty State -->
        <VerticalStackLayout x:Name="EmptyState" IsVisible="False"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Padding="20">
            <Label Text="No stores found" FontSize="16" HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
            <Label Text="Tap + to add your first store" FontSize="13" HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#999999, Dark=#666666}" />
        </VerticalStackLayout>

        <!-- Content -->
        <RefreshView x:Name="RefreshContainer" IsVisible="False" Refreshing="OnRefreshing">
            <CollectionView x:Name="StoresCollection" SelectionMode="Single" SelectionChanged="OnStoreSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItem Text="Delete" BackgroundColor="#E53935" Invoked="OnDeleteSwiped" />
                            </SwipeView.RightItems>
                            <Border Margin="10,4" Padding="12" StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,1" Radius="3" Opacity="0.08" />
                                </Border.Shadow>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <!-- Icon -->
                                    <Border Grid.Column="0" WidthRequest="40" HeightRequest="40"
                                            StrokeShape="RoundRectangle 20" Stroke="Transparent"
                                            BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B5E20}"
                                            VerticalOptions="Center">
                                        <Label Text="&#x1F3EA;" FontSize="18"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>

                                    <!-- Info -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding SubtitleDisplay}" FontSize="12"
                                               TextColor="{AppThemeBinding Light=#888888, Dark=#999999}"
                                               LineBreakMode="TailTruncation" />
                                        <Border Padding="4,2" StrokeShape="RoundRectangle 4" Stroke="Transparent"
                                                BackgroundColor="{Binding IntegrationBadgeColor}"
                                                IsVisible="{Binding HasIntegration}" HorizontalOptions="Start">
                                            <Label Text="{Binding IntegrationBadgeText}" FontSize="10"
                                                   FontAttributes="Bold" TextColor="White" />
                                        </Border>
                                    </VerticalStackLayout>

                                    <!-- Chevron -->
                                    <Label Grid.Column="2" Text="&#x203A;" FontSize="22" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#BDBDBD, Dark=#616161}" />
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>

</ContentPage>
