<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.Stores.StoreDetailPage"
             Title="Store"
             Shell.NavBarIsVisible="True">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Edit" Clicked="OnEditClicked" IconImageSource="pencil" />
    </ContentPage.ToolbarItems>

    <Grid>
        <!-- Loading -->
        <ActivityIndicator x:Name="LoadingIndicator"
                           IsRunning="True" IsVisible="True"
                           VerticalOptions="Center" HorizontalOptions="Center"
                           Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <!-- Error -->
        <Border x:Name="ErrorFrame" IsVisible="False" Margin="20" Padding="20"
                StrokeShape="RoundRectangle 10" Stroke="Transparent" BackgroundColor="#FFEBEE"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="10">
                <Label x:Name="ErrorLabel" TextColor="#C62828" HorizontalOptions="Center" />
                <Button Text="Retry" Clicked="OnRetryClicked" />
            </VerticalStackLayout>
        </Border>

        <!-- Content -->
        <ScrollView x:Name="ContentScroll" IsVisible="False">
            <VerticalStackLayout Spacing="0" Padding="15">

                <!-- Title -->
                <HorizontalStackLayout Spacing="10" Margin="0,0,0,8">
                    <Border WidthRequest="44" HeightRequest="44"
                            StrokeShape="RoundRectangle 22" Stroke="Transparent"
                            BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B5E20}"
                            VerticalOptions="Center">
                        <Label Text="&#x1F3EA;" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Label x:Name="TitleLabel" FontSize="24" FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </HorizontalStackLayout>

                <!-- Description -->
                <Border x:Name="DescriptionSection" IsVisible="False" Padding="12" Margin="0,0,0,12"
                        StrokeShape="RoundRectangle 10" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Description" FontSize="13" FontAttributes="Bold" TextColor="Gray" />
                        <Label x:Name="DescriptionLabel" FontSize="14"
                               TextColor="{AppThemeBinding Light=#424242, Dark=#BDBDBD}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Details Card -->
                <Border Padding="12" Margin="0,0,0,12" StrokeShape="RoundRectangle 10" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <VerticalStackLayout x:Name="DetailsStack" Spacing="6" />
                </Border>

                <!-- Integration Section -->
                <Border Padding="12" Margin="0,0,0,12" StrokeShape="RoundRectangle 10" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <VerticalStackLayout x:Name="IntegrationStack" Spacing="8">
                        <Label Text="Store Integration" FontSize="14" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Delete Button -->
                <Button x:Name="DeleteButton" Text="Delete Store" Clicked="OnDeleteClicked"
                        Margin="0,20,0,20" BackgroundColor="#E53935" TextColor="White" CornerRadius="8" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
