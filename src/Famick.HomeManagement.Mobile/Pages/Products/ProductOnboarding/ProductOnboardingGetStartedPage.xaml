<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.Products.ProductOnboarding.ProductOnboardingGetStartedPage"
             Title="Get Started"
             Shell.NavBarIsVisible="True"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <Grid RowDefinitions="*,Auto">
        <!-- Loading -->
        <ActivityIndicator x:Name="LoadingIndicator"
                           IsRunning="False"
                           IsVisible="False"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <!-- Error -->
        <Label x:Name="ErrorLabel"
               IsVisible="False"
               TextColor="#D32F2F"
               FontSize="14"
               Margin="16,8"
               VerticalOptions="Start" />

        <!-- Main content -->
        <ScrollView Grid.Row="0" Padding="20">
            <VerticalStackLayout Spacing="20" VerticalOptions="Center" HorizontalOptions="Center"
                                 MaximumWidthRequest="500">

                <!-- Success icon -->
                <Border WidthRequest="64" HeightRequest="64"
                        StrokeShape="RoundRectangle 32"
                        Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B5E20}"
                        HorizontalOptions="Center">
                    <Label Text="&#x2713;"
                           FontSize="32"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#2E7D32, Dark=#81C784}" />
                </Border>

                <Label Text="You're All Set!"
                       FontSize="24"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <Label Text="Your dietary preferences and allergen information have been saved. The best way to build your product catalog is to take inventory of what you already have at home."
                       FontSize="15"
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light=#555555, Dark=#BBBBBB}" />

                <!-- Hint card -->
                <Border Padding="16"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light=#42A5F5, Dark=#1565C0}"
                        BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#0D47A1}">
                    <Label Text="Walk through your kitchen, pantry, and fridge. As you add each product, pick a generic parent product from our catalog. This helps with recipes, shopping lists, and tracking stock across brands."
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#1565C0, Dark=#BBDEFB}" />
                </Border>

                <!-- Take Inventory button -->
                <Button x:Name="TakeInventoryButton"
                        Text="Take Inventory"
                        FontSize="16"
                        HeightRequest="48"
                        CornerRadius="10"
                        BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#42A5F5}"
                        TextColor="White"
                        Clicked="OnTakeInventoryClicked" />

                <!-- Later button -->
                <Button x:Name="LaterButton"
                        Text="I'll do this later"
                        FontSize="14"
                        HeightRequest="40"
                        CornerRadius="10"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"
                        Clicked="OnLaterClicked" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
