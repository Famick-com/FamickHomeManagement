<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.Products.ProductOnboarding.ProductOnboardingIntroPage"
             Title="Grocery Setup"
             Shell.NavBarIsVisible="True"
             Shell.FlyoutBehavior="Disabled">

    <ScrollView>
        <VerticalStackLayout Spacing="24" Padding="30,40,30,30">

            <!-- Icon -->
            <Label Text="&#x1F6D2;"
                   FontSize="64"
                   HorizontalOptions="Center" />

            <!-- Title -->
            <Label Text="Welcome to Shopping &amp; Inventory"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <!-- Description -->
            <Label FontSize="15"
                   LineBreakMode="WordWrap"
                   HorizontalTextAlignment="Center"
                   LineHeight="1.4"
                   TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}"
                   Text="To get you started, we'll ask a few quick questions about your household and preferences to build your product catalog." />

            <!-- Explanation cards -->
            <Border Padding="16" StrokeShape="RoundRectangle 12" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                <VerticalStackLayout Spacing="16">

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Label Grid.Column="0" Text="&#x1F4E6;" FontSize="24" VerticalOptions="Start" />
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Parent Products" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            <Label Text="We'll suggest common grocery items based on your answers. These become parent products in your catalog — general items like &quot;Milk&quot; or &quot;Bread.&quot;"
                                   FontSize="13" LineHeight="1.3"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Label Grid.Column="0" Text="&#x1F3F7;" FontSize="24" VerticalOptions="Start" />
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Your Specific Products" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            <Label Text="Later, you'll assign the specific brands and variants you actually buy as child products — like &quot;Whole Foods 365 Organic 2% Milk&quot; under &quot;Milk.&quot;"
                                   FontSize="13" LineHeight="1.3"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Label Grid.Column="0" Text="&#x1F4CA;" FontSize="24" VerticalOptions="Start" />
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Track Stock &amp; Shop Smarter" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            <Label Text="Once set up, you can track inventory, get low-stock alerts, and build shopping lists automatically."
                                   FontSize="13" LineHeight="1.3"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Get Started Button -->
            <Button Text="Get Started"
                    Clicked="OnGetStartedClicked"
                    BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    HeightRequest="50"
                    CornerRadius="10" />

            <!-- Skip Button -->
            <Button Text="Skip for now"
                    Clicked="OnSkipClicked"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#666666, Dark=#999999}"
                    HeightRequest="40" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
