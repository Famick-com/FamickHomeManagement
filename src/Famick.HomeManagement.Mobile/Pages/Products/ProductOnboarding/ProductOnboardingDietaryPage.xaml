<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.Products.ProductOnboarding.ProductOnboardingDietaryPage"
             Title="Grocery Setup (3 of 5)"
             Shell.NavBarIsVisible="True"
             Shell.FlyoutBehavior="Disabled">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30">

            <!-- Progress Indicator -->
            <Grid ColumnSpacing="8" HorizontalOptions="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <BoxView Grid.Column="0" WidthRequest="12" HeightRequest="12" CornerRadius="6" Color="#4CAF50" />
                <BoxView Grid.Column="1" WidthRequest="12" HeightRequest="12" CornerRadius="6" Color="#4CAF50" />
                <BoxView Grid.Column="2" WidthRequest="12" HeightRequest="12" CornerRadius="6" Color="#1976D2" />
                <BoxView Grid.Column="3" WidthRequest="12" HeightRequest="12" CornerRadius="6" Color="#BDBDBD" />
                <BoxView Grid.Column="4" WidthRequest="12" HeightRequest="12" CornerRadius="6" Color="#BDBDBD" />
            </Grid>

            <Label Text="Dietary Preferences"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Label Text="Select any that apply to your household. These help us filter product suggestions."
                   FontSize="14"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />

            <!-- Dietary Preferences Section -->
            <Border Padding="16" StrokeShape="RoundRectangle 12" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Dietary Preferences" FontAttributes="Bold" FontSize="15"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Label Text="Select any diets your household follows" FontSize="13"
                           TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                    <FlexLayout x:Name="DietaryChipsLayout" Wrap="Wrap" JustifyContent="Start"
                                AlignItems="Start" Direction="Row" />
                </VerticalStackLayout>
            </Border>

            <!-- Allergens Section -->
            <Border Padding="16" StrokeShape="RoundRectangle 12" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Allergens" FontAttributes="Bold" FontSize="15"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Label Text="Select allergens to avoid in product suggestions" FontSize="13"
                           TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                    <FlexLayout x:Name="AllergenChipsLayout" Wrap="Wrap" JustifyContent="Start"
                                AlignItems="Start" Direction="Row" />
                </VerticalStackLayout>
            </Border>

            <!-- Error Message -->
            <Label x:Name="ErrorLabel"
                   IsVisible="False"
                   TextColor="#E53935"
                   HorizontalOptions="Center" />

            <!-- Loading Indicator -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False"
                               IsVisible="False"
                               Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0" Text="Back"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        BorderColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"
                        BorderWidth="2"
                        TextColor="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}"
                        HeightRequest="50"
                        CornerRadius="10" />
                <Button Grid.Column="1" Text="Next"
                        Clicked="OnNextClicked"
                        BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}"
                        TextColor="White"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        CornerRadius="10" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
