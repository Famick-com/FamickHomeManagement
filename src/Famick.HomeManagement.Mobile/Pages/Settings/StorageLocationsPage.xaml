<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Famick.HomeManagement.Mobile.Pages.Settings.StorageLocationsPage"
             Title="Storage Locations"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+" Clicked="OnAddClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*">
        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" IsVisible="True"
                           VerticalOptions="Center" HorizontalOptions="Center"
                           Color="{AppThemeBinding Light=#1976D2, Dark=#90CAF9}" />

        <VerticalStackLayout x:Name="EmptyState" IsVisible="False"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Padding="20">
            <Label Text="No storage locations" FontSize="16" HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
            <Label Text="Tap + to add your first location" FontSize="13" HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#999999, Dark=#666666}" />
        </VerticalStackLayout>

        <RefreshView x:Name="RefreshContainer" IsVisible="False" Refreshing="OnRefreshing">
            <CollectionView x:Name="LocationsCollection">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItem Text="Delete" BackgroundColor="#D32F2F" Invoked="OnDeleteSwiped" />
                            </SwipeView.RightItems>
                            <Border Margin="10,4" Padding="12" StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,1" Radius="3" Opacity="0.08" />
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLocationTapped" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                        <Label Text="{Binding Description}" FontSize="12"
                                               TextColor="{AppThemeBinding Light=#888888, Dark=#999999}" />
                                        <HorizontalStackLayout Spacing="8">
                                            <Border Padding="4,2" StrokeShape="RoundRectangle 4" Stroke="Transparent"
                                                    BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B5E20}"
                                                    IsVisible="{Binding IsActive}">
                                                <Label Text="Active" FontSize="10"
                                                       TextColor="{AppThemeBinding Light=#2E7D32, Dark=#A5D6A7}" />
                                            </Border>
                                            <Border Padding="4,2" StrokeShape="RoundRectangle 4" Stroke="Transparent"
                                                    BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#B71C1C}"
                                                    IsVisible="{Binding IsInactive}">
                                                <Label Text="Inactive" FontSize="10"
                                                       TextColor="{AppThemeBinding Light=#C62828, Dark=#EF9A9A}" />
                                            </Border>
                                            <Label Text="{Binding SortOrder, StringFormat='Sort: {0}'}" FontSize="10"
                                                   TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#777777}"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1" Text="&#x203A;" FontSize="22" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#BDBDBD, Dark=#616161}" />
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
