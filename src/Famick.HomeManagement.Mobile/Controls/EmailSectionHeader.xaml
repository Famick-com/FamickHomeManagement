<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sfButtons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
             x:Class="Famick.HomeManagement.Mobile.Controls.EmailSectionHeader">
    <Grid ColumnDefinitions="36,*,Auto">
        <Label Grid.Column="0"
               Text="&#xe717;"
               FontSize="18"
               FontFamily="MaterialAssets"
               FontAttributes="Bold"
               VerticalOptions="Center"/>
        <Label Grid.Column="1"
               Text="Email Addresses"
               FontSize="16"
               FontAttributes="Bold"
               VerticalOptions="Center"/>
        <sfButtons:SfButton Grid.Column="2"
                            TextColor="{AppThemeBinding Light=#333333, Dark=White}"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=White}"
                            StrokeThickness="0"
                            EnableRippleEffect="True"
                            Text="&#xe70d;"
                            FontFamily="MaterialAssets"
                            Clicked="OnAddClicked"
                            WidthRequest="36"
                            HeightRequest="36"
                            CornerRadius="18"
                            FontSize="18"
                            Padding="0"
                            Background="{AppThemeBinding Light=White, Dark=Transparent}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=Transparent}"/>
    </Grid>
</ContentView>
