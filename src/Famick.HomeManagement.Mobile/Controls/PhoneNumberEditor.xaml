<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sfInputs="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
             x:Class="Famick.HomeManagement.Mobile.Controls.PhoneNumberEditor">
    <Grid ColumnDefinitions="110,*" ColumnSpacing="8">
        <Border x:Name="CountryButton"
                Grid.Column="0"
                Stroke="#D0D0D0"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 4"
                Padding="12,10"
                BackgroundColor="White"
                HeightRequest="44">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4" VerticalOptions="Center">
                <Label x:Name="CountryLabel"
                       Grid.Column="0"
                       Text="🇺🇸 +1"
                       VerticalOptions="Center"
                       FontSize="16"
                       TextColor="Black" />
                <Label Grid.Column="1"
                       Text="▾"
                       VerticalOptions="Center"
                       FontSize="12"
                       TextColor="#666" />
            </Grid>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCountryTapped" />
            </Border.GestureRecognizers>
        </Border>
        <sfInputs:SfMaskedEntry x:Name="NumberEntry"
                                Grid.Column="1"
                                MaskType="Simple"
                                Mask="(000) 000-0000"
                                ClearButtonVisibility="Never"
                                Keyboard="Telephone"
                                ValueChanged="OnNumberChanged" />
    </Grid>
</ContentView>
